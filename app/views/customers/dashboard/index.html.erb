<!-- 온보딩 플로우 (첫 방문자용) -->
<%= render "shared/onboarding" %>


<!-- 당근마켓 스타일 고객 대시보드 -->
<div class="min-h-screen bg-gray-50 pb-20 md:pb-8">
  <div class="max-w-4xl mx-auto px-4 py-6 md:pt-0">
    <!-- 인사 카드 -->
    <div class="bg-gradient-to-r from-primary-600 to-primary-700 rounded-3xl p-6 mb-6 text-white shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-[26px] font-bold mb-1 leading-tight">
            안녕하세요, <%= current_user.name || current_user.email.split('@').first %>님! 👋
          </h1>
          <p class="text-primary-100 text-[15px]">오늘도 안전한 하루 되세요</p>
        </div>
        <%= link_to customers_profile_path, class: "flex-shrink-0 w-12 h-12 bg-white bg-opacity-20 rounded-full flex items-center justify-center hover:bg-opacity-30 transition" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- 빠른 액션 (당근마켓 스타일) -->
    <div class="grid grid-cols-3 gap-3.5 mb-6">
      <%= link_to new_customers_request_path, id: "cta-new-check", class: "bg-white rounded-2xl p-5 text-center hover:shadow-lg transition-all border-2 border-gray-100 hover:border-primary-200 card-hover" do %>
        <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
          </svg>
        </div>
        <p class="text-sm font-bold text-gray-900">누수 체크</p>
        <p class="text-xs text-gray-500 mt-1">새로 접수</p>
      <% end %>

      <%= link_to customers_requests_path, class: "bg-white rounded-2xl p-5 text-center hover:shadow-lg transition-all border-2 border-gray-100 hover:border-primary-200 card-hover" do %>
        <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
        <p class="text-sm font-bold text-gray-900">내 요청</p>
        <p class="text-xs text-gray-500 mt-1"><%= @active_requests.count %>건</p>
      <% end %>

      <%= link_to customers_insurance_claims_path, class: "bg-white rounded-2xl p-5 text-center hover:shadow-lg transition-all border-2 border-gray-100 hover:border-primary-200 card-hover" do %>
        <div class="w-14 h-14 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </div>
        <p class="text-sm font-bold text-gray-900">보험 신청</p>
        <p class="text-xs text-gray-500 mt-1">간편하게</p>
      <% end %>
    </div>

    <!-- 통계 카드 (당근마켓 스타일) -->
    <div class="grid grid-cols-3 gap-3.5 mb-6">
      <div class="bg-white rounded-2xl p-4 text-center border-2 border-gray-100">
        <p class="text-2xl font-extrabold text-primary-600"><%= @active_requests.count %></p>
        <p class="text-xs text-gray-600 mt-1">진행중</p>
      </div>

      <div class="bg-white rounded-2xl p-4 text-center border-2 border-gray-100">
        <p class="text-2xl font-extrabold text-yellow-600"><%= @pending_estimates.count %></p>
        <p class="text-xs text-gray-600 mt-1">견적대기</p>
      </div>

      <div class="bg-white rounded-2xl p-4 text-center border-2 border-gray-100">
        <p class="text-2xl font-extrabold text-green-600"><%= @recent_completed.count %></p>
        <p class="text-xs text-gray-600 mt-1">완료</p>
      </div>
    </div>

    <!-- 진행 중인 체크 (당근마켓 스타일) -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900">진행 중인 체크</h2>
        <%= link_to "전체 보기 →", customers_requests_path, class: "text-primary-600 hover:text-primary-700 text-sm font-semibold transition-colors" %>
      </div>

      <% if @active_requests.any? %>
        <div class="space-y-3">
          <% @active_requests.each do |request| %>
            <% thumb_photo = request.photos.first %>
            <% thumb_video = request.videos.first %>
            <%= link_to request_messages_path(request), class: "block bg-white rounded-2xl p-4 hover:shadow-lg transition-all border-2 border-gray-100 hover:border-primary-200 card-hover" do %>
              <div class="flex items-start gap-4">
                <%# 썸네일 %>
                <div class="w-20 h-20 rounded-xl overflow-hidden flex-shrink-0 bg-gray-100">
                  <% if thumb_photo.present? %>
                    <%= image_tag thumb_photo.variant(resize_to_fill: [160, 160]), class: "w-full h-full object-cover" %>
                  <% elsif thumb_video.present? %>
                    <video src="<%= url_for(thumb_video) %>" class="w-full h-full object-cover" muted preload="metadata" style="pointer-events:none"></video>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center">
                      <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                    </div>
                  <% end %>
                </div>

                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-2">
                    <%= render "shared/status_badge", status: request.status %>
                    <span class="text-xs text-gray-400"><%= time_ago_in_words(request.created_at) %> 전</span>
                  </div>
                  <h3 class="font-bold text-gray-900 mb-1 text-base"><%= symptom_label(request.symptom_type) %></h3>
                  <div class="flex items-center gap-1.5 text-xs text-gray-500">
                    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="truncate"><%= request.address %></span>
                  </div>
                  <% if request.master %>
                    <div class="flex items-center gap-1.5 mt-2">
                      <div class="w-5 h-5 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-3 h-3 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                        </svg>
                      </div>
                      <span class="text-xs text-gray-600 font-medium"><%= request.master.name || request.master.email.split('@').first %></span>
                    </div>
                  <% else %>
                    <p class="mt-2 text-xs text-orange-500 font-medium">⏳ 전문가 매칭 중...</p>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-2xl p-10 text-center border-2 border-dashed border-gray-200">
          <img src="/images/characters/hello.png" alt="" class="w-28 h-28 mx-auto mb-4 object-contain" loading="lazy" />
          <p class="text-gray-600 mb-4 font-medium">진행 중인 체크가 없어요</p>
          <p class="text-sm text-gray-500 mb-6">누수가 의심되면 바로 체크해보세요</p>
          <%= link_to new_customers_request_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-xl hover:bg-primary-700 transition-all font-bold shadow-md" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
            </svg>
            <span>새 체크 접수하기</span>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- 최근 완료된 체크 -->
    <% if @recent_completed.any? %>
      <div class="mb-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">최근 완료</h2>
        <div class="space-y-3">
          <% @recent_completed.each do |request| %>
            <%= link_to customers_request_path(request), class: "block bg-white rounded-2xl p-4 hover:shadow-lg transition-all border-2 border-gray-100 hover:border-green-200" do %>
              <div class="flex items-center justify-between mb-2">
                <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold">
                  ✓ 완료
                </span>
                <span class="text-xs text-gray-500">
                  <%= request.closed_at&.strftime("%m/%d") %>
                </span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-1 text-sm">
                <%= symptom_label(request.symptom_type) %>
              </h3>
              <p class="text-xs text-gray-600 line-clamp-1"><%= request.address %></p>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- 도움말 카드 -->
    <div class="bg-primary-50 rounded-2xl p-5 border-2 border-primary-100">
      <h3 class="text-sm font-bold text-primary-900 mb-3 flex items-center gap-2">
        <span>💡</span>
        <span>이용 가이드</span>
      </h3>
      <ul class="space-y-2 text-xs text-primary-800">
        <li class="flex items-start gap-2">
          <span class="text-primary-600 font-bold">•</span>
          <span>영상 첨부 시 더 정확한 진단이 가능해요</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 font-bold">•</span>
          <span>견적은 24시간 이내에 제공됩니다</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-primary-600 font-bold">•</span>
          <span>완료 후 리뷰로 다른 고객을 도와주세요</span>
        </li>
      </ul>
    </div>
  </div>
</div>
