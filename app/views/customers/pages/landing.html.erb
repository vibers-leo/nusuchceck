<!-- 토스 스타일 고객 앱 랜딩페이지 -->
<div class="min-h-screen bg-gradient-to-br from-primary-50 via-white to-purple-50">
  <!-- 히어로 섹션 -->
  <div class="max-w-6xl mx-auto px-4 pt-20 pb-16">
    <!-- 메인 캐치프레이즈 -->
    <div class="text-center mb-16 animate-fade-in">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-100 rounded-full mb-6">
        <span class="w-2 h-2 bg-primary-600 rounded-full animate-pulse"></span>
        <span class="text-sm font-bold text-primary-700">AI 기반 누수 진단 플랫폼</span>
      </div>

      <h1 class="text-5xl md:text-6xl font-extrabold text-gray-900 mb-6 leading-tight">
        누수, <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-purple-600">10분</span>이면<br class="md:hidden"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600">해결됩니다</span>
      </h1>

      <p class="text-xl md:text-2xl text-gray-600 mb-10 leading-relaxed">
        영상 하나로 AI가 진단하고,<br class="md:hidden"/>
        검증된 전문가가 24시간 내 견적을 드려요
      </p>

      <!-- CTA 버튼 -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <%= link_to new_user_registration_path, class: "w-full sm:w-auto inline-flex items-center justify-center gap-3 px-10 py-6 bg-gradient-to-r from-primary-600 to-purple-600 text-white rounded-2xl hover:shadow-2xl transition-all font-bold text-xl group hover:scale-105 shadow-lg" do %>
          <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
          </svg>
          <span>무료로 시작하기</span>
          <span class="px-2 py-0.5 bg-white bg-opacity-20 rounded-full text-xs">30초 완료</span>
        <% end %>

        <%= link_to new_user_session_path, class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-5 bg-white text-gray-700 rounded-2xl hover:bg-gray-50 transition-all font-semibold text-lg border-2 border-gray-200 hover:border-primary-300" do %>
          <span>이미 회원이에요</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <!-- 신뢰 지표 (강화된 버전) -->
      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-6 inline-block">
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
          <div class="text-center">
            <div class="flex items-center justify-center gap-1 mb-1">
              <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span class="text-3xl font-extrabold text-gray-900">4.8</span>
              <span class="text-gray-400 text-sm">/5.0</span>
            </div>
            <p class="text-xs text-gray-500 font-medium">고객 만족도</p>
          </div>

          <div class="hidden md:block w-px h-12 bg-gray-200"></div>

          <div class="text-center">
            <div class="flex items-center justify-center gap-1 mb-1">
              <span class="text-3xl font-extrabold text-primary-600">500</span>
              <span class="text-primary-600 text-xl font-bold">+</span>
            </div>
            <p class="text-xs text-gray-500 font-medium">검증된 전문가</p>
          </div>

          <div class="hidden md:block w-px h-12 bg-gray-200"></div>

          <div class="text-center">
            <div class="flex items-center justify-center gap-1 mb-1">
              <span class="text-3xl font-extrabold text-green-600">2</span>
              <span class="text-gray-400 text-sm">시간</span>
            </div>
            <p class="text-xs text-gray-500 font-medium">평균 응답시간</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 프로세스 (통일된 그라디언트) -->
    <div class="grid md:grid-cols-3 gap-6 mb-20">
      <!-- Step 1 -->
      <div class="group bg-gradient-to-br from-primary-50 to-purple-100 rounded-3xl p-8 border-2 border-primary-200 hover:shadow-2xl transition-all hover:-translate-y-2 duration-300">
        <div class="w-16 h-16 bg-gradient-to-br from-primary-600 to-purple-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">
          <img src="/images/characters/upload.png" alt="" class="w-10 h-10 object-contain" loading="lazy">
        </div>
        <div class="flex items-center gap-2 mb-3">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary-600 text-white font-bold text-sm">1</span>
          <h3 class="text-2xl font-bold text-gray-900">영상 촬영</h3>
        </div>
        <p class="text-gray-700 leading-relaxed">
          누수 부위를 <strong class="text-primary-600">10초 이상</strong> 촬영하세요.<br/>
          AI가 자동으로 분석해드려요.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="group bg-gradient-to-br from-primary-50 to-purple-100 rounded-3xl p-8 border-2 border-primary-200 hover:shadow-2xl transition-all hover:-translate-y-2 duration-300 md:mt-4">
        <div class="w-16 h-16 bg-gradient-to-br from-primary-600 to-purple-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">
          <img src="/images/characters/ai-robot.png" alt="" class="w-10 h-10 object-contain" loading="lazy">
        </div>
        <div class="flex items-center gap-2 mb-3">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary-600 text-white font-bold text-sm">2</span>
          <h3 class="text-2xl font-bold text-gray-900">AI 진단</h3>
        </div>
        <p class="text-gray-700 leading-relaxed">
          <strong class="text-primary-600">평균 2시간 내</strong> 검증된 전문가가<br/>
          정확한 견적을 제공해드려요.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="group bg-gradient-to-br from-primary-50 to-purple-100 rounded-3xl p-8 border-2 border-primary-200 hover:shadow-2xl transition-all hover:-translate-y-2 duration-300 md:mt-8">
        <div class="w-16 h-16 bg-gradient-to-br from-primary-600 to-purple-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">
          <img src="/images/icons/verified.png" alt="" class="w-10 h-10 object-contain" loading="lazy">
        </div>
        <div class="flex items-center gap-2 mb-3">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-primary-600 text-white font-bold text-sm">3</span>
          <h3 class="text-2xl font-bold text-gray-900">안심 수리</h3>
        </div>
        <p class="text-gray-700 leading-relaxed">
          에스크로 결제로 안전하게,<br/>
          보험청구까지 <strong class="text-primary-600">자동으로</strong> 처리해요.
        </p>
      </div>
    </div>

    <!-- 특징 -->
    <div class="bg-white rounded-3xl p-10 shadow-xl border border-gray-100 mb-16">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">
        왜 <span class="text-primary-600">누수체크</span>일까요?
      </h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">빠른 응답</h4>
            <p class="text-gray-600">영상 업로드 후 평균 2시간 내 견적 제공</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">안전 결제</h4>
            <p class="text-gray-600">에스크로로 완료 후 결제, 환불 보장</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">보험 자동화</h4>
            <p class="text-gray-600">서류 자동 생성, 클릭 한 번에 보험 청구</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">투명한 가격</h4>
            <p class="text-gray-600">표준 견적으로 합리적인 가격 보장</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 고객 후기 -->
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-3">
        <span class="text-primary-600">5,000+</span> 고객님의 선택
      </h2>
      <p class="text-center text-gray-600 mb-10">실제 이용하신 고객님들의 생생한 후기예요</p>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- 후기 1 -->
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-all">
          <div class="flex items-center gap-1 mb-3">
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            "화장실 천장 누수로 걱정했는데, 영상 올리고 2시간 만에 견적 받았어요. 보험청구 서류도 자동으로 만들어줘서 정말 편했습니다!"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-primary-600 to-purple-600 rounded-full flex items-center justify-center text-white font-bold">
              김
            </div>
            <div>
              <p class="font-semibold text-gray-900">김**님</p>
              <p class="text-xs text-gray-500">서울 강남구 · 아파트</p>
            </div>
          </div>
        </div>

        <!-- 후기 2 -->
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-all">
          <div class="flex items-center gap-1 mb-3">
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            "에스크로 결제라 안심하고 맡겼어요. 작업 완료 후 결제되니 사기 걱정 없이 좋았습니다. 전문가님도 친절하셨어요!"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-primary-600 to-purple-600 rounded-full flex items-center justify-center text-white font-bold">
              이
            </div>
            <div>
              <p class="font-semibold text-gray-900">이**님</p>
              <p class="text-xs text-gray-500">경기 성남시 · 빌라</p>
            </div>
          </div>
        </div>

        <!-- 후기 3 -->
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-all">
