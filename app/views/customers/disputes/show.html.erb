<div class="max-w-2xl mx-auto px-4 py-6">
  <!-- 헤더 -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="text-xs text-gray-400"><%= @dispute.dispute_number %></p>
      <h1 class="text-xl font-bold text-gray-900"><%= @dispute.category_label %></h1>
    </div>
    <span class="text-xs font-medium px-3 py-1 rounded-full
      <%= case @dispute.status
          when 'opened', 'expert_response' then 'bg-yellow-100 text-yellow-700'
          when 'mediation' then 'bg-blue-100 text-blue-700'
          when 'resolved', 'auto_resolved' then 'bg-green-100 text-green-700'
          when 'cancelled' then 'bg-gray-100 text-gray-500'
          end %>">
      <%= case @dispute.status
          when 'opened' then '접수됨'
          when 'expert_response' then '전문가 답변 대기'
          when 'mediation' then '중재 진행 중'
          when 'resolved' then '해결 완료'
          when 'auto_resolved' then '자동 해결'
          when 'cancelled' then '취소됨'
          end %>
    </span>
  </div>

  <!-- 분쟁 내용 -->
  <div class="bg-white border border-gray-200 rounded-2xl p-4 mb-4">
    <p class="text-sm text-gray-700"><%= simple_format(@dispute.description) %></p>
    <% if @dispute.disputed_amount.present? %>
      <p class="text-sm font-bold text-primary-600 mt-3">분쟁 금액: <%= number_to_currency(@dispute.disputed_amount, unit: "원", format: "%n%u") %></p>
    <% end %>
  </div>

  <!-- 중재 결정 (해결된 경우) -->
  <% if @dispute.resolved? || @dispute.auto_resolved? %>
    <div class="bg-green-50 border border-green-200 rounded-2xl p-4 mb-4">
      <p class="text-sm font-bold text-green-800 mb-1">
        <%= @dispute.resolution_label %>
        <% if @dispute.refund_percentage.present? %>
          (<%= @dispute.refund_percentage %>%)
        <% end %>
      </p>
      <p class="text-sm text-green-700"><%= @dispute.resolution_note %></p>
    </div>
  <% end %>

  <!-- 기한 안내 -->
  <% if @dispute.opened? && @dispute.expert_response_deadline.present? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-3 mb-4">
      <p class="text-xs text-yellow-700">
        전문가 답변 기한: <strong><%= @dispute.expert_response_deadline.strftime("%m/%d %H:%M") %></strong>
        <% if @dispute.overdue? %>
          <span class="text-red-600 font-bold">(기한 초과)</span>
        <% end %>
      </p>
    </div>
  <% end %>

  <!-- 증거 자료 -->
  <% if @evidences.any? %>
    <div class="bg-white border border-gray-200 rounded-2xl p-4 mb-4">
      <h2 class="text-sm font-bold text-gray-900 mb-3">증거 자료</h2>
      <div class="space-y-2">
        <% @evidences.each do |evidence| %>
          <div class="flex items-center gap-3 bg-gray-50 rounded-xl p-3">
            <span class="text-lg"><%= { "photo" => "📷", "video" => "🎥", "document" => "📄", "receipt" => "🧾" }[evidence.evidence_type] || "📎" %></span>
            <div class="flex-1">
              <p class="text-xs font-medium text-gray-700"><%= evidence.type_label %></p>
              <p class="text-xs text-gray-400"><%= evidence.submitted_by&.name %> · <%= evidence.created_at.strftime("%m/%d %H:%M") %></p>
              <% if evidence.description.present? %>
                <p class="text-xs text-gray-500 mt-1"><%= evidence.description %></p>
              <% end %>
            </div>
            <% if evidence.files.attached? %>
              <span class="text-xs text-primary-500"><%= evidence.files.count %>개 파일</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 대화 내역 -->
  <div class="bg-white border border-gray-200 rounded-2xl p-4 mb-4">
    <h2 class="text-sm font-bold text-gray-900 mb-3">대화 내역</h2>
    <div class="space-y-3 max-h-96 overflow-y-auto">
      <% @messages.each do |msg| %>
        <div class="<%= msg.system? ? 'text-center' : (msg.sender_id == current_user.id ? 'text-right' : 'text-left') %>">
          <% if msg.system? %>
            <p class="text-xs text-gray-400 bg-gray-50 rounded-lg px-3 py-2 inline-block"><%= msg.content %></p>
          <% else %>
            <p class="text-xs text-gray-500 mb-1"><%= msg.sender_name %></p>
            <div class="inline-block max-w-xs px-4 py-2 rounded-2xl text-sm
              <%= msg.sender_id == current_user.id ? 'bg-primary-500 text-white' : 'bg-gray-100 text-gray-800' %>">
              <%= simple_format(msg.content) %>
            </div>
            <p class="text-[10px] text-gray-400 mt-1"><%= msg.created_at.strftime("%H:%M") %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 메시지 입력 -->
  <% unless @dispute.resolved? || @dispute.auto_resolved? || @dispute.cancelled? %>
    <%= form_with url: add_message_customers_dispute_path(@dispute), method: :post, class: "flex gap-2 mb-4" do %>
      <%= text_field_tag :content, nil, placeholder: "메시지를 입력하세요...", class: "flex-1 border border-gray-300 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-primary-500" %>
      <%= submit_tag "전송", class: "bg-primary-500 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-primary-600 cursor-pointer" %>
    <% end %>

    <!-- 취소 버튼 -->
    <% if @dispute.may_cancel? %>
      <%= link_to "분쟁 취소", cancel_customers_dispute_path(@dispute), method: :post, data: { confirm: "정말 분쟁을 취소할까요?" }, class: "text-sm text-gray-400 hover:text-red-500" %>
    <% end %>
  <% end %>
</div>
