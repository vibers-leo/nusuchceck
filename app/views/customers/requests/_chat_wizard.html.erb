<%# 대화형 챗봇 스타일 누수 접수 마법사 %>
<div class="flex flex-col bg-gray-50"
     style="height: calc(100vh - 4rem);"
     data-controller="chat-wizard"
     data-chat-wizard-user-address-value="<%= current_user.try(:address).to_s %>">

  <!-- 헤더 -->
  <div class="bg-white border-b border-gray-100 px-4 py-3.5 flex items-center justify-between flex-shrink-0">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-primary-100 rounded-full flex items-center justify-center">
        <img src="/images/characters/ai-robot.png" alt="" class="w-6 h-6 object-contain" loading="lazy">
      </div>
      <div>
        <p class="text-sm font-bold text-gray-900">누수 AI 도우미</p>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
          <span class="text-xs text-gray-400">온라인 · 즉시 응답</span>
        </div>
      </div>
    </div>
    <%= link_to customers_dashboard_path,
          class: "w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100 transition text-gray-400" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    <% end %>
  </div>

  <!-- 채팅 영역 (스크롤) -->
  <div data-chat-wizard-target="chatArea"
       class="flex-1 overflow-y-auto px-4 py-5 space-y-4"
       style="padding-bottom: 1.5rem;">

    <!-- 타이핑 인디케이터 (JS로 표시/숨김) -->
    <div data-chat-wizard-target="typingIndicator" class="hidden flex items-end gap-2 bubble-fade-in">
      <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0 mb-1">
        <img src="/images/characters/ai-robot.png" alt="" class="w-5 h-5 object-contain" loading="lazy">
      </div>
      <div class="bg-white border border-gray-100 rounded-2xl rounded-bl-md px-4 py-3 shadow-sm">
        <div class="flex items-center gap-1.5">
          <span class="typing-dot w-2 h-2 rounded-full bg-gray-400 inline-block"></span>
          <span class="typing-dot w-2 h-2 rounded-full bg-gray-400 inline-block"></span>
          <span class="typing-dot w-2 h-2 rounded-full bg-gray-400 inline-block"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- 하단 답변 패널 (fixed, 하단 네비 위) -->
  <div data-chat-wizard-target="answerPanel"
       class="fixed bottom-16 left-0 right-0 bg-white border-t border-gray-100 px-4 pt-4 pb-4 z-40 md:bottom-0"
       style="box-shadow: 0 -4px 20px rgba(0,0,0,0.06);">

    <!-- 패널: initial — 긴급 / 점검 선택 -->
    <div data-panel="initial" class="hidden space-y-2.5">
      <button type="button"
              data-action="click->chat-wizard#selectUrgent"
              class="w-full flex items-center gap-3 py-4 px-5 rounded-2xl bg-red-500 text-white font-bold text-sm hover:bg-red-600 active:scale-[0.98] transition-all">
        <span class="text-xl flex-shrink-0"></span>
        <div class="text-left">
          <p class="font-bold">네, 지금 당장 누수 중이에요</p>
          <p class="text-xs text-red-200 font-normal mt-0.5">빠른 출동 요청</p>
        </div>
      </button>
      <button type="button"
              data-action="click->chat-wizard#selectPrecheck"
              class="w-full flex items-center gap-3 py-4 px-5 rounded-2xl border-2 border-primary-200 bg-primary-50 text-primary-800 font-bold text-sm hover:border-primary-400 active:scale-[0.98] transition-all">
        <img src="/images/icons/inspect.png" alt="" class="w-7 h-7 flex-shrink-0 object-contain" loading="lazy">
        <div class="text-left">
          <p class="font-bold">아니요, 점검이나 진단이 필요해요</p>
          <p class="text-xs text-primary-500 font-normal mt-0.5">사전 점검 예약</p>
        </div>
      </button>
    </div>

    <!-- 패널: symptom — 증상 선택 -->
    <div data-panel="symptom" class="hidden">
      <p class="text-xs text-gray-400 font-medium mb-3">해당하는 증상을 선택해주세요</p>
      <div class="grid grid-cols-3 gap-2">
        <% [
          { value: "wall_leak",    label: "벽면 누수",   icon: "leak" },
          { value: "ceiling_leak", label: "천장 누수",   icon: "leak" },
          { value: "floor_leak",   label: "바닥 누수",   icon: "leak" },
          { value: "pipe_leak",    label: "배관 누수",   icon: "tools" },
          { value: "toilet_leak",  label: "화장실 누수", icon: "leak" },
          { value: "outdoor_leak", label: "외부 누수",   icon: "houses" },
        ].each do |symptom| %>
          <button type="button"
                  data-action="click->chat-wizard#selectSymptom"
                  data-value="<%= symptom[:value] %>"
                  data-label="<%= symptom[:label] %>"
                  class="flex flex-col items-center gap-1.5 py-3.5 rounded-2xl border-2 border-gray-100 bg-white hover:border-primary-300 hover:bg-primary-50 active:scale-[0.96] transition-all">
            <img src="/images/icons/<%= symptom[:icon] %>.png" alt="" class="w-8 h-8 object-contain">
            <span class="text-xs font-semibold text-gray-700"><%= symptom[:label] %></span>
          </button>
        <% end %>
      </div>
    </div>

    <!-- 패널: building — 건물 선택 -->
    <div data-panel="building" class="hidden">
      <p class="text-xs text-gray-400 font-medium mb-3">건물 종류를 선택해주세요</p>
      <div class="grid grid-cols-2 gap-2">
        <% [
          { value: "apartment",      label: "아파트",    icon: "houses" },
          { value: "villa",          label: "빌라/연립", icon: "houses" },
          { value: "house",          label: "단독주택",  icon: "houses" },
          { value: "office",         label: "사무실",    icon: "houses" },
          { value: "retail_store",   label: "상가",      icon: "houses" },
          { value: "other_building", label: "기타",      icon: "houses" },
        ].each do |building| %>
          <button type="button"
                  data-action="click->chat-wizard#selectBuilding"
                  data-value="<%= building[:value] %>"
                  data-label="<%= building[:label] %>"
                  class="flex items-center gap-3 py-3.5 px-4 rounded-2xl border-2 border-gray-100 bg-white hover:border-primary-300 hover:bg-primary-50 active:scale-[0.96] transition-all">
            <img src="/images/icons/<%= building[:icon] %>.png" alt="" class="w-8 h-8 object-contain">
            <span class="text-sm font-semibold text-gray-700"><%= building[:label] %></span>
          </button>
        <% end %>
      </div>
    </div>

    <!-- 패널: address — 주소 입력 -->
    <div data-panel="address" class="hidden space-y-2">
      <div class="flex gap-2">
        <input type="text"
               data-chat-wizard-target="addressInput"
               readonly
               placeholder="주소를 검색해주세요"
               class="flex-1 border-2 border-gray-200 rounded-xl px-3 py-2.5 text-sm bg-gray-50 focus:outline-none focus:border-primary-400 transition-colors">
        <button type="button"
                data-action="click->chat-wizard#openAddressSearch"
                class="px-4 py-2.5 bg-primary-500 text-white rounded-xl text-sm font-bold hover:bg-primary-600 transition-colors flex-shrink-0">
          검색
        </button>
      </div>
      <input type="text"
             data-chat-wizard-target="detailAddressInput"
             placeholder="상세주소 (동/호수, 층수 등)"
             class="w-full border-2 border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-primary-400 transition-colors">
      <button type="button"
              data-action="click->chat-wizard#submitAddress"
              class="w-full py-3.5 bg-primary-500 text-white rounded-2xl font-bold text-sm hover:bg-primary-600 active:scale-[0.98] transition-all">
        확인
      </button>
    </div>

    <!-- 패널: description — 상황 설명 (선택) -->
    <div data-panel="description" class="hidden space-y-2">
      <textarea data-chat-wizard-target="descInput"
                rows="3"
                placeholder="예: 화장실 천장에서 물이 떨어지고 있어요..."
                class="w-full border-2 border-gray-200 rounded-xl px-3 py-2.5 text-sm resize-none focus:outline-none focus:border-primary-400 transition-colors leading-relaxed"></textarea>
      <div class="flex gap-2">
        <button type="button"
                data-action="click->chat-wizard#skipDescription"
                class="flex-1 py-3.5 border-2 border-gray-200 text-gray-500 rounded-2xl font-semibold text-sm hover:border-gray-300 active:scale-[0.98] transition-all">
          건너뛰기
        </button>
        <button type="button"
                data-action="click->chat-wizard#submitDescription"
                class="flex-1 py-3.5 bg-primary-500 text-white rounded-2xl font-bold text-sm hover:bg-primary-600 active:scale-[0.98] transition-all">
          다음
        </button>
      </div>
    </div>

    <!-- 패널: media — 영상/사진 업로드 (선택) -->
    <div data-panel="media" class="hidden space-y-2">
      <input type="file"
             id="chat-media-upload"
             multiple
             accept="image/*,video/*"
             capture="environment"
             class="hidden"
             data-action="change->chat-wizard#onMediaSelected">
      <label for="chat-media-upload"
             class="flex items-center gap-3 p-4 border-2 border-dashed border-gray-200 rounded-2xl cursor-pointer hover:border-primary-300 hover:bg-primary-50 transition-all">
        <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-gray-900">사진 또는 영상 선택</p>
          <p class="text-xs text-gray-400 mt-0.5">
            <span data-chat-wizard-target="mediaCount" class="hidden text-primary-600 font-semibold"></span>
            <span class="media-hint">이미지, 동영상 · 여러 개 가능</span>
          </p>
        </div>
      </label>
      <div class="flex gap-2">
        <button type="button"
                data-action="click->chat-wizard#skipMedia"
                class="flex-1 py-3.5 border-2 border-gray-200 text-gray-500 rounded-2xl font-semibold text-sm hover:border-gray-300 active:scale-[0.98] transition-all">
          나중에 올릴게요
        </button>
        <button type="button"
                data-action="click->chat-wizard#submitMedia"
                class="flex-1 py-3.5 bg-primary-500 text-white rounded-2xl font-bold text-sm hover:bg-primary-600 active:scale-[0.98] transition-all">
          다음
        </button>
      </div>
    </div>

    <!-- 패널: submit — 최종 제출 -->
    <div data-panel="submit" class="hidden">
      <%= form_with(model: [:customers, f_request],
                    html: { multipart: true },
                    data: {
                      chat_wizard_target: "submitForm",
                      controller: "button-loading",
                      action: "submit->button-loading#submit"
                    }) do |f| %>

        <%# 수집된 데이터 hidden fields (JS로 값 설정) %>
        <%= f.hidden_field :symptom_type,      data: { chat_wizard_target: "fieldSymptom" } %>
        <%= f.hidden_field :building_type,     data: { chat_wizard_target: "fieldBuilding" } %>
        <%= f.hidden_field :address,           data: { chat_wizard_target: "fieldAddress" } %>
        <%= f.hidden_field :detailed_address,  data: { chat_wizard_target: "fieldDetailAddress" } %>
        <%= f.hidden_field :description,       data: { chat_wizard_target: "fieldDescription" } %>
        <%= f.hidden_field :request_source,    data: { chat_wizard_target: "fieldSource" } %>

        <div class="space-y-3">
          <!-- 안심 메시지 -->
          <div class="flex items-center gap-2 p-3 bg-gray-50 rounded-xl">
            <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <p class="text-xs text-gray-500">검증된 전문가만 매칭 · 에스크로 안전 결제</p>
          </div>

          <%= f.button type: "submit",
                data: {
                  button_loading_target: "button",
                  "button-loading-loading-text-value": "접수 중..."
                },
                class: "w-full py-4 rounded-2xl bg-primary-500 text-white font-bold text-base hover:bg-primary-600 active:scale-[0.98] transition-all" do %>
            <span data-button-loading-target="spinner" class="btn-spinner hidden"></span>
            <span data-chat-wizard-target="submitLabel" data-button-loading-target="text">전문가에게 요청하기</span>
          <% end %>
        </div>
      <% end %>
    </div>

  </div><!-- /answerPanel -->
</div>
