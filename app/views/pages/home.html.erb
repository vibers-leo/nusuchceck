</section>

<!-- 보험 파트너 배너 -->
<section class="py-10 bg-gradient-to-r from-indigo-50 to-blue-50 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 border-y border-indigo-100">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-indigo-500 font-semibold uppercase tracking-wide">보험 파트너</p>
          <p class="font-bold text-gray-900">일상배상책임보험으로 누수 피해를 보장받으세요</p>
          <p class="text-sm text-gray-500 mt-0.5">누수로 인한 이웃 피해까지 간편하게 청구. 토스 보험 제휴.</p>
        </div>
      </div>
      <a href="#" class="flex-shrink-0 inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-all">
        보험 알아보기
        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- CTA 섹션 -->
<section class="py-16 text-center">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">지금 바로 시작하세요</h2>
    <p class="text-gray-600 mb-8">누수 걱정, 더 이상 혼자 고민하지 마세요.</p>
    <% unless user_signed_in? %>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl bg-blue-700 text-white hover:bg-blue-800 shadow-lg hover:shadow-xl transition-all duration-200" do %>
          무료 회원가입
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
        <%= link_to new_leak_inspection_path, class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl border-2 border-blue-700 text-blue-700 hover:bg-blue-50 transition-all duration-200" do %>
          AI 점검 먼저 해보기
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- 전문가 초대 섹션 -->
<% unless user_signed_in? %>
<section class="py-12 bg-emerald-50 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">누수 전문가이신가요?</h3>
        <p class="text-gray-600">업계 평균(30~40%) 대비 낮은 수수료로 더 많은 수익을.</p>
        <p class="text-gray-600">수도배관·방수 전문가 파트너를 모집합니다.</p>
      </div>
      <%= link_to expert_root_path, class: "flex-shrink-0 inline-flex items-center px-6 py-3 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition-all" do %>
        전문가 등록 알아보기
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
  </div>
</section>
<% end %>
