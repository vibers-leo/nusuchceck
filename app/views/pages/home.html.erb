<!-- Hero Section - 당근마켓 스타일 -->
<section class="relative bg-gradient-to-br from-blue-700 via-blue-600 to-blue-800 -mx-4 sm:-mx-6 lg:-mx-8 -mt-8 px-4 sm:px-6 lg:px-8 py-16 md:py-24 overflow-hidden">
  <!-- 배경 이미지 -->
  <div class="absolute inset-0 opacity-35">
    <img src="https://images.pexels.com/photos/7836293/pexels-photo-7836293.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750"
         alt="배경"
         class="w-full h-full object-cover"
         loading="eager">
  </div>
  <div class="absolute inset-0 bg-gradient-to-br from-blue-900/40 to-blue-800/60"></div>

  <div class="relative max-w-4xl mx-auto">
    <!-- AI 진단 배너 (당근마켓 스타일) -->
    <div class="bg-white/95 backdrop-blur-sm rounded-3xl p-8 md:p-10 shadow-2xl border-4 border-blue-200 mb-8">
      <div class="flex flex-col md:flex-row items-center gap-6">
        <!-- 큰 카메라 아이콘 -->
        <div class="flex-shrink-0">
          <div class="w-20 h-20 md:w-24 md:h-24 bg-gradient-to-br from-blue-600 to-blue-700 rounded-3xl flex items-center justify-center shadow-xl">
            <svg class="w-12 h-12 md:w-14 md:h-14 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
        </div>

        <!-- 텍스트 콘텐츠 -->
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-2">
            AI 누수 진단으로<br class="md:hidden"> 먼저 확인하세요
          </h2>
          <p class="text-base md:text-lg text-gray-700 mb-1">
            사진 1장으로 예상 수리비와 원인을 분석해드려요
          </p>
          <p class="text-sm text-blue-600 font-semibold">
            ⚡️ 평균 2시간 이내 전문가 배정 · 💯 검증된 전문가만
          </p>
        </div>
      </div>

      <!-- 액션 버튼 -->
      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <% if user_signed_in? %>
          <% if current_user.customer? %>
            <%= link_to new_customers_request_path, class: "flex-1 inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-2xl bg-gradient-to-r from-blue-600 to-blue-700 text-white hover:from-blue-700 hover:to-blue-800 shadow-lg hover:shadow-xl transition-all duration-200" do %>
              <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              누수 체크하기
            <% end %>
          <% elsif current_user.master? %>
            <%= link_to masters_requests_path, class: "flex-1 inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-2xl bg-gradient-to-r from-blue-600 to-blue-700 text-white hover:from-blue-700 hover:to-blue-800 shadow-lg hover:shadow-xl transition-all duration-200" do %>
              오더 목록 보기
            <% end %>
          <% end %>
        <% else %>
          <%= link_to new_customers_request_path, class: "flex-1 inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-2xl bg-gradient-to-r from-blue-600 to-blue-700 text-white hover:from-blue-700 hover:to-blue-800 shadow-lg hover:shadow-xl transition-all duration-200" do %>
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            무료로 시작하기
          <% end %>
          <%= link_to new_leak_inspection_path, class: "flex-1 inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-2xl border-2 border-blue-700 text-blue-700 hover:bg-blue-50 transition-all duration-200" do %>
            AI 빠른 점검
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- 신뢰 배지 (간소화) -->
    <div class="grid grid-cols-3 gap-4 text-center text-white">
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 border border-white/20">
        <p class="text-2xl font-extrabold">150+</p>
        <p class="text-xs text-blue-100 mt-1">검증된 전문가</p>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 border border-white/20">
        <p class="text-2xl font-extrabold">95%</p>
        <p class="text-xs text-blue-100 mt-1">매칭 성공률</p>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 border border-white/20">
        <p class="text-2xl font-extrabold">2시간</p>
        <p class="text-xs text-blue-100 mt-1">평균 배정시간</p>
      </div>
    </div>
  </div>
</section>


<!-- 4개 핵심 기능 카드 (당근마켓 스타일) -->
<section class="py-12 md:py-16">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      <!-- 1. 누수 점검 요청 -->
      <div class="bg-white rounded-2xl p-6 text-center hover:shadow-lg transition-all cursor-pointer border border-gray-100">
        <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-9 h-9 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 text-base mb-1">누수 점검 요청</h3>
        <p class="text-xs text-gray-500">온전 시 0원 보증</p>
      </div>

      <!-- 2. 안심 에스크로 -->
      <div class="bg-white rounded-2xl p-6 text-center hover:shadow-lg transition-all cursor-pointer border border-gray-100">
        <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-9 h-9 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 text-base mb-1">안심 에스크로</h3>
        <p class="text-xs text-gray-500">수리 확인 후 결제</p>
      </div>

      <!-- 3. 2년 무상 AS -->
      <div class="bg-white rounded-2xl p-6 text-center hover:shadow-lg transition-all cursor-pointer border border-gray-100">
        <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-9 h-9 text-purple-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 text-base mb-1">2년 무상 AS</h3>
        <p class="text-xs text-gray-500">하자보수 보증</p>
      </div>

      <!-- 4. 전문가 지원 -->
      <div class="bg-white rounded-2xl p-6 text-center hover:shadow-lg transition-all cursor-pointer border border-gray-100">
        <div class="w-16 h-16 bg-yellow-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-9 h-9 text-yellow-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 text-base mb-1">전문가 지원</h3>
        <p class="text-xs text-gray-500">파트너스 전환하기</p>
      </div>
    </div>
  </div>
</section>

<!-- 장점 섹션 -->
<section class="py-16 md:py-20 bg-gray-100 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">왜 누수체크인가요?</h2>
      <p class="mt-3 text-lg text-gray-500">고객과 전문가 모두를 위한 신뢰 기반 플랫폼</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- 장점 1: 공평한 매칭 -->
      <div class="flex items-start bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <div class="flex-shrink-0 w-12 h-12 bg-green-100 text-green-600 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">검증된 전문가</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            자격증, 경력, 보험 가입 여부를 철저히 심사합니다. 검증을 통과한 전문가만 활동합니다.
          </p>
        </div>
      </div>

      <!-- 장점 2: 에스크로 결제 -->
      <div class="flex items-start bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <div class="flex-shrink-0 w-12 h-12 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">단계별 에스크로</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            출장비→검사비→공사비를 단계별로 에스크로 보관. 공사 완료 확인 후 정산이 이루어져 양측 모두 안심합니다.
          </p>
        </div>
      </div>

      <!-- 장점 3: 투명 가격 -->
      <div class="flex items-start bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <div class="flex-shrink-0 w-12 h-12 bg-yellow-100 text-yellow-600 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">표준 견적 시스템</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            표준화된 견적 항목으로 투명한 가격을 제공합니다. 마케팅 수수료 없이 합리적인 비용으로 이용하세요.
          </p>
        </div>
      </div>

      <!-- 장점 4: 보험서류 자동화 -->
      <div class="flex items-start bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <div class="flex-shrink-0 w-12 h-12 bg-purple-100 text-purple-600 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">보험서류 자동화</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            보험 청구에 필요한 탐지 보고서, 견적서, 시공 완료 보고서를 PDF로 자동 생성합니다.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AI 빠른 점검 CTA -->
<section class="py-16 bg-gradient-to-r from-purple-600 to-blue-600 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto text-center text-white">
    <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm font-medium mb-4">AI 무료 서비스</span>
    <h2 class="text-3xl font-bold mb-4">AI로 누수 여부를 즉시 확인하세요</h2>
    <p class="text-lg text-blue-100 mb-8">사진 한 장이면 충분합니다. 로그인 없이 무료로 이용하세요.</p>
    <%= link_to new_leak_inspection_path, class: "inline-flex items-center px-8 py-4 bg-white text-blue-700 rounded-xl font-semibold hover:bg-gray-100 shadow-lg transition-all duration-200" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      AI 빠른 점검 시작
    <% end %>
  </div>
</section>

<!-- 앱 다운로드 섹션 -->
