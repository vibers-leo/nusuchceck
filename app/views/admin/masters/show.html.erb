<div class="space-y-6">
  <!-- 뒤로가기 + 헤더 -->
  <%= render "shared/page_header",
      title: "마스터: #{@master.name}",
      back_path: admin_masters_path,
      back_text: "목록으로" %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- 좌측: 정보 -->
    <div class="lg:col-span-2 space-y-6">
      <!-- 프로필 정보 -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <div class="flex items-start space-x-4 mb-6">
          <div class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
            <span class="text-primary-600 font-bold text-2xl"><%= @master.name&.first %></span>
          </div>
          <div>
            <h2 class="text-xl font-bold text-gray-900"><%= @master.name %></h2>
            <p class="text-sm text-gray-500"><%= @master.email %></p>
            <p class="text-sm text-gray-500"><%= @master.phone %></p>
          </div>
        </div>

        <% profile = @master.master_profile %>
        <% if profile.present? %>
          <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
            <div>
              <dt class="text-sm font-medium text-gray-500">자격증 번호</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= profile.license_number || "-" %></dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">경력</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= profile.experience_years ? "#{profile.experience_years}년" : "-" %></dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">인증 상태</dt>
              <dd class="mt-1">
                <% if profile.verified? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800" role="status">인증 완료</span>
                  <span class="text-xs text-gray-500 ml-2"><%= profile.verified_at&.strftime("%Y-%m-%d") %></span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800" role="status">미인증</span>
                <% end %>
              </dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">평점</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <% if @master.average_rating > 0 %>
                  <span class="text-yellow-500 font-bold"><%= @master.average_rating %></span>
                  (<%= @master.total_reviews_count %>건)
                <% else %>
                  리뷰 없음
                <% end %>
              </dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">보유 장비</dt>
              <dd class="mt-1">
                <% if profile.equipment_list.any? %>
                  <div class="flex flex-wrap gap-1">
                    <% profile.equipment_list.each do |equip| %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-700"><%= equip %></span>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-sm text-gray-500">-</span>
                <% end %>
              </dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">서비스 지역</dt>
              <dd class="mt-1">
                <% if profile.service_areas_list.any? %>
                  <div class="flex flex-wrap gap-1">
                    <% profile.service_areas_list.each do |area| %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-primary-100 text-primary-700"><%= area %></span>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-sm text-gray-500">-</span>
                <% end %>
              </dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">계좌 정보</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= [profile.bank_name, profile.account_number, profile.account_holder].compact_blank.join(" / ").presence || "-" %></dd>
            </div>
          </dl>
        <% end %>
      </div>

      <!-- 최근 체크 -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">최근 배정 체크</h2>
        <% recent_requests = @master.assigned_requests.recent.limit(10) %>
        <% if recent_requests.any? %>
          <div class="space-y-2">
            <% recent_requests.each do |request| %>
              <div class="flex items-center justify-between p-3 border rounded-lg hover:bg-gray-50">
                <%= link_to admin_request_path(request), class: "flex-1 flex items-center justify-between" do %>
                  <div>
                    <span class="font-mono text-sm text-primary-600">#<%= request.id %></span>
                    <span class="ml-2 text-sm text-gray-900"><%= request.customer&.name %></span>
                  </div>
                  <div class="flex items-center gap-2">
                    <%= render "shared/status_badge", status: request.status %>
                    <span class="text-xs text-gray-500"><%= request.created_at.strftime("%m/%d") %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">배정된 체크가 없습니다.</p>
        <% end %>
      </div>

      <!-- 리뷰 목록 -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">리뷰</h2>
        <% if @master.reviews.any? %>
          <div class="space-y-4">
            <% @master.reviews.recent.limit(10).each do |review| %>
              <div class="border rounded-lg p-4">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-medium text-gray-900"><%= review.customer&.name %></span>
                  <div class="flex items-center">
                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <span class="ml-1 text-sm font-bold text-gray-900"><%= review.overall_rating %></span>
                  </div>
                </div>
                <div class="flex flex-wrap gap-3 text-xs text-gray-500 mb-2">
                  <% review.rating_labels.each do |key, label| %>
                    <% rating_val = review.send("#{key}_rating") %>
                    <% if rating_val %>
                      <span><%= label %>: <%= rating_val %></span>
                    <% end %>
                  <% end %>
                </div>
                <% if review.comment.present? %>
                  <p class="text-sm text-gray-700"><%= review.comment %></p>
                <% end %>
                <p class="text-xs text-gray-500 mt-2"><%= review.created_at.strftime("%Y-%m-%d") %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">등록된 리뷰가 없습니다.</p>
        <% end %>
      </div>
    </div>

    <!-- 우측: 관리 액션 -->
    <div class="space-y-6">
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">인증 관리</h2>
        <div class="space-y-3">
          <% if @master.verified? %>
            <p class="text-sm text-green-600 font-medium">이 마스터는 인증되었습니다.</p>
            <%= button_to "인증 취소",
                  reject_admin_master_path(@master),
                  method: :post,
                  class: "#{btn_classes(:danger, :md)} w-full",
                  data: { turbo_confirm: "정말 인증을 취소하시겠습니까?" } %>
          <% else %>
            <p class="text-sm text-yellow-600 font-medium">이 마스터는 미인증 상태입니다.</p>
            <%= button_to "인증 승인",
                  verify_admin_master_path(@master),
                  method: :post,
                  class: "#{btn_classes(:success, :md)} w-full",
                  data: { turbo_confirm: "이 마스터를 인증하시겠습니까?" } %>
            <%= button_to "인증 거절",
                  reject_admin_master_path(@master),
                  method: :post,
                  class: "#{btn_classes(:danger, :md)} w-full",
                  data: { turbo_confirm: "인증을 거절하시겠습니까?" } %>
          <% end %>
        </div>
      </div>

      <!-- 배상책임보험 인증 관리 -->
      <% if @profile.present? %>
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">배상책임보험 인증</h2>

          <% if @profile.insurance_active? %>
            <div class="flex items-center gap-2 p-3 bg-green-50 rounded-xl mb-3">
              <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <div class="text-xs">
                <p class="font-semibold text-green-700">인증 완료</p>
                <p class="text-green-600"><%= @profile.insurance_insurer_name %> · 만기 <%= @profile.insurance_valid_until&.strftime("%Y.%m.%d") %></p>
              </div>
            </div>
          <% end %>

          <% if @profile.insurance_pending_review? %>
            <!-- OCR 결과 표시 -->
            <% ocr = @profile.insurance_ocr_data&.with_indifferent_access || {} %>
            <div class="bg-amber-50 rounded-xl p-4 mb-3 space-y-2">
              <p class="text-xs font-bold text-amber-700 mb-2">검토 대기 중 — OCR 자동 인식 결과</p>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <div>
                  <span class="text-gray-500">보험사</span>
                  <p class="font-semibold text-gray-900"><%= ocr[:insurer_name].presence || "인식 불가" %></p>
                </div>
                <div>
                  <span class="text-gray-500">만기일</span>
                  <p class="font-semibold text-gray-900"><%= ocr[:valid_until].presence || "인식 불가" %></p>
                </div>
                <div>
                  <span class="text-gray-500">피보험자</span>
                  <p class="font-semibold text-gray-900"><%= ocr[:insured_name].presence || "인식 불가" %></p>
                </div>
                <div>
                  <span class="text-gray-500">배상책임 포함</span>
                  <p class="font-semibold <%= ocr[:has_liability_coverage] ? 'text-green-700' : 'text-red-600' %>">
                    <%= ocr[:has_liability_coverage] ? "✓ 포함" : "✗ 미확인" %>
                  </p>
                </div>
              </div>
              <% if @profile.insurance_certificate.attached? %>
                <div class="pt-2 border-t border-amber-200">
                  <%= link_to "원본 서류 보기",
                        url_for(@profile.insurance_certificate),
                        target: "_blank",
                        class: "text-xs text-primary-600 font-semibold underline" %>
                </div>
              <% end %>
            </div>
            <div class="flex gap-2">
              <%= button_to "인증 승인",
                    approve_insurance_admin_master_path(@master),
                    method: :post,
                    class: "flex-1 py-2 text-xs font-bold rounded-xl bg-green-600 text-white hover:bg-green-700",
                    data: { turbo_confirm: "보험 인증을 승인할까요?" } %>
              <%= button_to "거절",
                    reject_insurance_admin_master_path(@master),
                    method: :post,
                    class: "flex-1 py-2 text-xs font-bold rounded-xl bg-red-50 text-red-600 hover:bg-red-100",
                    data: { turbo_confirm: "보험 인증을 거절할까요?" } %>
            </div>
          <% elsif !@profile.insurance_active? %>
            <p class="text-xs text-gray-400 text-center py-2">제출된 서류 없음</p>
          <% end %>

          <% if @profile.insurance_active? %>
            <%= button_to "인증 취소",
                  reject_insurance_admin_master_path(@master),
                  method: :post,
                  class: "w-full mt-2 py-2 text-xs font-semibold rounded-xl bg-gray-100 text-gray-600 hover:bg-gray-200",
                  data: { turbo_confirm: "보험 인증을 취소할까요?" } %>
          <% end %>
        </div>
      <% end %>

      <!-- 통계 요약 -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">활동 요약</h2>
        <dl class="space-y-3 text-sm">
          <div class="flex justify-between">
            <dt class="text-gray-500">전체 체크</dt>
            <dd class="font-medium text-gray-900"><%= @master.assigned_requests.count %>건</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">진행중 체크</dt>
            <dd class="font-medium text-gray-900"><%= @master.active_requests.count %>건</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">리뷰 수</dt>
            <dd class="font-medium text-gray-900"><%= @master.total_reviews_count %>건</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">가입일</dt>
            <dd class="font-medium text-gray-900"><%= @master.created_at.strftime("%Y-%m-%d") %></dd>
          </div>
        </dl>
      </div>

      <!-- 프로필 콘텐츠 점검 -->
      <% profile = @master.master_profile %>
      <% if profile.present? %>
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-3">
              <h3 class="text-base font-bold text-gray-900">프로필 콘텐츠 점검</h3>
              <%= link_to edit_admin_master_path(@master), class: "text-xs text-primary-600 font-semibold hover:underline" do %>
                직접 수정하기
              <% end %>
            </div>
            <% case profile.profile_review_status
               when "approved" %>
              <span class="px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700">점검 완료</span>
            <% when "flagged" %>
              <span class="px-3 py-1 rounded-full text-xs font-bold bg-red-100 text-red-700">수정 요청</span>
            <% else %>
              <span class="px-3 py-1 rounded-full text-xs font-bold bg-amber-100 text-amber-700">미점검</span>
            <% end %>
          </div>

          <!-- 프로필 미리보기 -->
          <div class="space-y-4 mb-6">
            <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl">
              <% if profile.profile_photo.attached? %>
                <%= image_tag profile.profile_photo.variant(resize_to_fill: [64, 64]), class: "w-16 h-16 rounded-xl object-cover flex-shrink-0" %>
              <% else %>
                <div class="w-16 h-16 rounded-xl bg-gray-200 flex items-center justify-center flex-shrink-0">
                  <span class="text-gray-400 text-xs">사진없음</span>
                </div>
              <% end %>
              <div>
                <p class="text-sm font-bold text-gray-900"><%= @master.name %></p>
                <p class="text-xs text-primary-600 mt-0.5"><%= profile.tagline.presence || "(한 줄 소개 없음)" %></p>
                <p class="text-xs text-gray-500 mt-1 line-clamp-2"><%= profile.bio.presence || "(자기소개 없음)" %></p>
              </div>
            </div>

            <% if profile.certifications_list.any? %>
              <div>
                <p class="text-xs font-semibold text-gray-500 mb-1.5">자격증</p>
                <div class="flex flex-wrap gap-1.5">
                  <% profile.certifications_list.each do |cert| %>
                    <span class="px-2 py-0.5 bg-amber-50 text-amber-700 text-xs rounded-full border border-amber-100"><%= cert %></span>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if profile.work_photos.attached? %>
              <div>
                <p class="text-xs font-semibold text-gray-500 mb-1.5">시공 사례 사진 (<%= profile.work_photos.count %>장)</p>
                <div class="grid grid-cols-4 gap-1.5">
                  <% profile.work_photos.each do |photo| %>
                    <%= image_tag photo.variant(resize_to_fill: [120, 90]), class: "w-full h-20 object-cover rounded-lg" %>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if profile.intro_video_url.present? %>
              <div>
                <p class="text-xs font-semibold text-gray-500 mb-1">소개 영상</p>
                <a href="<%= profile.intro_video_url %>" target="_blank" class="text-xs text-primary-600 hover:underline truncate block"><%= profile.intro_video_url %></a>
              </div>
            <% end %>
          </div>

          <!-- 점검 액션 -->
          <%= form_with url: "#", method: :post, class: "space-y-3", id: "profile_review_form" do |f| %>
            <div>
              <label class="block text-xs font-semibold text-gray-500 mb-1">점검 메모 (선택)</label>
              <textarea name="review_notes" rows="2" placeholder="수정 요청 사유 또는 메모"
                class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-300 focus:outline-none resize-none"></textarea>
            </div>
            <div class="flex gap-2">
              <%= link_to approve_profile_admin_master_path(@master), method: :post,
                    data: { turbo_confirm: "프로필을 승인할까요?" },
                    class: "flex-1 py-2.5 text-center text-sm font-bold rounded-xl bg-green-600 text-white hover:bg-green-700 transition" do %>
                승인
              <% end %>
              <%= link_to flag_profile_admin_master_path(@master), method: :post,
                    data: { turbo_confirm: "수정 요청을 보낼까요?" },
                    class: "flex-1 py-2.5 text-center text-sm font-semibold rounded-xl bg-white border border-red-300 text-red-600 hover:bg-red-50 transition" do %>
                수정 요청
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
