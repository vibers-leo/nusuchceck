<div class="max-w-lg mx-auto px-4 py-6">
  <h1 class="text-xl font-bold text-gray-900 mb-6"><%= @zone.new_record? ? "구역 추가" : "구역 수정" %></h1>

  <%= form_with(model: [:admin, @zone], class: "space-y-4") do |f| %>
    <% if @zone.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4">
        <% @zone.errors.full_messages.each do |msg| %>
          <p class="text-sm text-red-600"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">지역</label>
      <%= f.text_field :region, placeholder: "서울", class: "w-full border rounded-xl px-4 py-2 text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">구역명</label>
      <%= f.text_field :name, placeholder: "강남", class: "w-full border rounded-xl px-4 py-2 text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">포함 구 (쉼표로 구분)</label>
      <input type="text" name="service_zone[districts][]" value="<%= @zone.districts_text %>" placeholder="강남구, 서초구" class="w-full border rounded-xl px-4 py-2 text-sm">
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">인구</label>
        <%= f.number_field :population, class: "w-full border rounded-xl px-4 py-2 text-sm" %>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">최대 슬롯</label>
        <%= f.number_field :max_slots, min: 1, class: "w-full border rounded-xl px-4 py-2 text-sm" %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= f.check_box :active, class: "rounded" %>
      <label class="text-sm text-gray-700">활성화</label>
    </div>

    <div class="flex gap-2">
      <%= f.submit @zone.new_record? ? "생성" : "저장", class: "flex-1 bg-primary-500 text-white py-2 rounded-xl text-sm font-semibold cursor-pointer hover:bg-primary-600" %>
      <%= link_to "취소", admin_service_zones_path, class: "flex-1 text-center bg-gray-100 text-gray-600 py-2 rounded-xl text-sm" %>
    </div>
  <% end %>
</div>
