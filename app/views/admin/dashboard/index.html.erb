<div class="space-y-6 fade-in">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">관리자 대시보드</h1>
    <p class="text-sm text-gray-500"><%= Time.current.strftime("%Y년 %m월 %d일 %H:%M") %></p>
  </div>

  <!-- 승인 대기 전문가 (있을 때만 표시) -->
  <% if @pending_masters.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <span class="flex w-2.5 h-2.5 bg-amber-500 rounded-full animate-pulse"></span>
          <h2 class="text-base font-bold text-amber-900">승인 대기 중인 전문가 (<%= @pending_masters.size %>명)</h2>
        </div>
        <%= link_to "전체 보기", admin_masters_path, class: "text-sm text-amber-700 hover:text-amber-900 font-medium" %>
      </div>
      <div class="space-y-2">
        <% @pending_masters.each do |master| %>
          <div class="bg-white rounded-xl border border-amber-100 px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-amber-100 flex items-center justify-center text-amber-700 font-bold text-sm flex-shrink-0">
                <%= master.name&.first %>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= master.name %></p>
                <p class="text-xs text-gray-500"><%= master.email %> · 가입 <%= time_ago_in_words(master.created_at) %> 전</p>
                <% profile = master.master_profile %>
                <% if profile %>
                  <p class="text-xs text-gray-400 mt-0.5">경력 <%= profile.experience_years || "-" %>년 · <%= profile.bio&.truncate(30) %></p>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0 ml-4">
              <%= link_to "프로필", admin_master_path(master), class: "px-3 py-1.5 text-xs font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors" %>
              <%= button_to "승인", verify_admin_master_path(master), method: :post,
                    class: "px-3 py-1.5 text-xs font-bold text-white bg-green-600 rounded-lg hover:bg-green-700 transition-colors",
                    data: { turbo_confirm: "#{master.name} 전문가를 승인하시겠습니까?" },
                    form: { class: "inline" } %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 통계 카드 -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="stat-cards">
    <%
      cards = [
        { metric: "requests",        icon_bg: "bg-primary-100", icon_color: "text-primary-600",
          label: "전체 체크",        value: @total_requests,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>' },
        { metric: "active_requests", icon_bg: "bg-yellow-100", icon_color: "text-yellow-600",
          label: "진행중 체크",      value: @active_requests,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>' },
        { metric: "masters",         icon_bg: "bg-green-100",   icon_color: "text-green-600",
          label: "전체 마스터",      value: @total_masters,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>' },
        { metric: "verified",        icon_bg: "bg-primary-100", icon_color: "text-primary-600",
          label: "인증 마스터",      value: @verified_masters,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>' },
        { metric: "escrow",          icon_bg: "bg-purple-100",  icon_color: "text-purple-600",
          label: "대기 에스크로",    value: @pending_escrows,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>' },
        { metric: "revenue",         icon_bg: "bg-red-100",     icon_color: "text-red-600",
          label: "총 수수료 매출",   value: number_to_currency(@revenue, unit: "₩", precision: 0),
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>' },
        { metric: "insurance",       icon_bg: "bg-indigo-100",  icon_color: "text-indigo-600",
          label: "전체 보험청구",    value: @total_insurance_claims,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>' },
        { metric: "ins_pending",     icon_bg: "bg-orange-100",  icon_color: "text-orange-600",
          label: "작성/검토 대기",   value: @pending_insurance_claims,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>' },
      ]
    %>
    <% cards.each do |card| %>
      <button type="button" onclick="toggleMetric('<%= card[:metric] %>')"
              id="card-<%= card[:metric] %>"
              class="bg-white rounded-2xl border border-gray-100 p-6 card-hover text-left w-full transition-all hover:border-primary-300 focus:outline-none focus:ring-2 focus:ring-primary-300 group">
        <div class="flex items-center">
          <div class="flex-shrink-0 <%= card[:icon_bg] %> rounded-lg p-3">
            <svg class="w-6 h-6 <%= card[:icon_color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <%= card[:icon].html_safe %>
            </svg>
          </div>
          <div class="ml-4 flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-500"><%= card[:label] %></p>
            <p class="text-2xl font-bold text-gray-900"><%= card[:value] %></p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-primary-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </button>
    <% end %>
  </div>

  <!-- 드릴다운 테이블 패널 -->
  <div id="drill-panel" class="hidden">
    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
      <!-- 패널 헤더 -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 bg-gray-50">
        <div class="flex items-center gap-2">
          <h3 id="drill-title" class="text-sm font-bold text-gray-900"></h3>
          <span class="text-xs text-gray-400">최근 30일 · 일자별</span>
        </div>
        <button type="button" onclick="closeDrill()" class="text-gray-400 hover:text-gray-600">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- 테이블 래퍼 -->
      <div class="overflow-x-auto max-h-96 overflow-y-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 sticky top-0 z-10">
            <tr id="drill-thead"></tr>
          </thead>
          <tbody id="drill-tbody" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- 📈 차트 섹션 -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">📈 30일 체크 추이</h2>
      <div class="h-56">
        <canvas id="requestTrendChart"></canvas>
      </div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">증상 유형 분포</h2>
      <div class="h-56 flex items-center justify-center">
        <canvas id="symptomChart"></canvas>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">  6개월 수수료 수익</h2>
      <div class="h-48">
        <canvas id="revenueChart"></canvas>
      </div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 p-6 flex flex-col justify-center">
      <h2 class="text-base font-semibold text-gray-900 mb-4">처리 현황</h2>
      <div class="space-y-4">
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600">완료율</span>
            <span class="font-medium"><%= @total_requests > 0 ? (@completed_count * 100.0 / @total_requests).round(1) : 0 %>%</span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-2">
            <div class="bg-green-500 h-2 rounded-full" style="width: <%= @total_requests > 0 ? (@completed_count * 100.0 / @total_requests).round(1) : 0 %>%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600">마스터 인증률</span>
            <span class="font-medium"><%= @total_masters > 0 ? (@verified_masters * 100.0 / @total_masters).round(1) : 0 %>%</span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-2">
            <div class="bg-primary-500 h-2 rounded-full" style="width: <%= @total_masters > 0 ? (@verified_masters * 100.0 / @total_masters).round(1) : 0 %>%"></div>
          </div>
        </div>
        <div class="pt-2 border-t border-gray-100 grid grid-cols-2 gap-3 text-center">
          <div>
            <p class="text-2xl font-bold text-green-600"><%= @completed_count %></p>
            <p class="text-xs text-gray-500">완료 건</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-primary-600"><%= @active_requests %></p>
            <p class="text-xs text-gray-500">진행 중</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Chart.js — data-turbo-track으로 Turbo가 CDN을 중복 로드하지 않도록 -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" data-turbo-track="reload"></script>
  <script>
    // 드릴다운 전역 상태 — 맨 위에 선언해야 TDZ 에러 없음
    var activeMetric = null;
    var drillCharts  = {};  // Chart 인스턴스 보관

    <%
      trend_labels = (29.downto(0)).map { |i| (Date.current - i.days).strftime("%m/%d") }
      trend_data   = (29.downto(0)).map { |i| @monthly_requests[(Date.current - i.days).to_s] || 0 }
      symptom_map  = { 'wall_leak'=>'벽면','ceiling_leak'=>'천장','floor_leak'=>'바닥','pipe_leak'=>'배관','toilet_leak'=>'화장실','outdoor_leak'=>'외부' }
      s_labels     = @symptom_distribution.map { |k, _| symptom_map[k] || k }
      s_data       = @symptom_distribution.values
      rev_labels   = @monthly_revenue.keys
      rev_data     = @monthly_revenue.values.map(&:to_f)
    %>

    // Chart.js가 로드된 후 실행 (Turbo Drive 재진입 대응)
    function initCharts() {
      if (typeof Chart === 'undefined') return;

      // 기존 인스턴스 파괴 (Turbo 캐시 재진입 시 canvas 재사용 오류 방지)
      ['requestTrendChart','symptomChart','revenueChart'].forEach(id => {
        const existing = Chart.getChart(id);
        if (existing) existing.destroy();
      });

    new Chart(document.getElementById('requestTrendChart'), {
      type: 'bar',
      data: {
        labels: <%= trend_labels.to_json.html_safe %>,
        datasets: [{ label: '체크', data: <%= trend_data.to_json.html_safe %>,
          backgroundColor: 'rgba(13,148,136,0.6)', borderColor: 'rgb(13,148,136)',
          borderWidth: 1, borderRadius: 4 }]
      },
      options: { responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { x: { grid: { display:false }, ticks: { font:{size:10}, maxTicksLimit:10 } },
                  y: { beginAtZero:true, ticks: { stepSize:1, font:{size:10} } } } }
    });
    new Chart(document.getElementById('symptomChart'), {
      type: 'doughnut',
      data: {
        labels: <%= s_labels.to_json.html_safe %>,
        datasets: [{ data: <%= s_data.to_json.html_safe %>,
          backgroundColor: ['#0d9488','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'],
          borderWidth: 2, borderColor: '#fff' }]
      },
      options: { responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position:'bottom', labels:{ font:{size:11}, padding:8, boxWidth:12 } } } }
    });
    new Chart(document.getElementById('revenueChart'), {
      type: 'line',
      data: {
        labels: <%= rev_labels.to_json.html_safe %>,
        datasets: [{ label: '수수료(₩)', data: <%= rev_data.to_json.html_safe %>,
          borderColor: 'rgb(16,185,129)', backgroundColor: 'rgba(16,185,129,0.1)',
          borderWidth: 2, tension: 0.4, fill: true, pointBackgroundColor: 'rgb(16,185,129)' }]
      },
      options: { responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display:false } },
        scales: { x: { grid:{display:false}, ticks:{font:{size:11}} },
                  y: { beginAtZero:true, ticks:{ font:{size:10},
                    callback: (v) => '₩' + v.toLocaleString() } } } }
    });

    } // end initCharts

    // ── 드릴다운 데이터 (Rails → JS) ──────────────────────────────────────
    var ROWS = <%= @daily_rows.to_json.html_safe %>;

    var METRICS = {
      requests: {
        title: "전체 체크 — 일자별",
        cols: ["일자", "요일", "신규 접수", "완료", "누적"],
        row:  function(r) { return [r.date, r.weekday, r.new_req, r.done_req, r.req_cum]; },
        highlights: [2]
      },
      active_requests: {
        title: "진행중 체크 — 일자별",
        cols: ["일자", "요일", "신규 접수", "당일 완료"],
        row:  function(r) { return [r.date, r.weekday, r.new_req, r.done_req]; },
        highlights: [2]
      },
      masters: {
        title: "전체 마스터 현황",
        cols: ["이름", "인증", "보험", "지역", "경력", "작업", "완료", "평점", "가입"],
        custom: true,
        data: <%= @master_list.to_json.html_safe %>,
        highlights: [5, 6]
      },
      verified: {
        title: "인증 마스터 현황",
        cols: ["이름", "인증", "보험", "지역", "경력", "작업", "완료", "평점", "가입"],
        custom: true,
        data: <%= @master_list.select { |m| m[:verified] }.to_json.html_safe %>,
        highlights: [5, 6]
      },
      escrow: {
        title: "에스크로 입금 — 일자별",
        cols: ["일자", "요일", "신규 입금 건"],
        row:  function(r) { return [r.date, r.weekday, r.escrow_dep]; },
        highlights: [2]
      },
      revenue: {
        title: "수수료 매출 — 일자별",
        cols: ["일자", "요일", "수수료 수입"],
        row:  function(r) { return [r.date, r.weekday, '₩' + r.revenue.toLocaleString()]; },
        highlights: [2]
      },
      insurance: {
        title: "보험청구 — 일자별",
        cols: ["일자", "요일", "신규 청구", "누적"],
        row:  function(r) { return [r.date, r.weekday, r.new_ins, r.ins_cum]; },
        highlights: [2]
      },
      ins_pending: {
        title: "보험청구 신규 접수 — 일자별",
        cols: ["일자", "요일", "신규 청구"],
        row:  function(r) { return [r.date, r.weekday, r.new_ins]; },
        highlights: [2]
      },
    };

    function toggleMetric(metric) {
      const panel = document.getElementById('drill-panel');
      // 같은 카드 재클릭 → 닫기
      if (activeMetric === metric) {
        closeDrill();
        return;
      }
      activeMetric = metric;

      // 카드 활성 스타일
      document.querySelectorAll('[id^="card-"]').forEach(c => {
        c.classList.remove('border-primary-400', 'ring-2', 'ring-primary-200', 'bg-primary-50');
      });
      const activeCard = document.getElementById('card-' + metric);
      if (activeCard) activeCard.classList.add('border-primary-400', 'ring-2', 'ring-primary-200', 'bg-primary-50');

      const cfg = METRICS[metric];
      document.getElementById('drill-title').textContent = cfg.title;

      // 헤더
      const thead = document.getElementById('drill-thead');
      thead.innerHTML = cfg.cols.map((col, i) =>
        `<th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap ${i === 0 ? 'sticky left-0 bg-gray-50' : ''}">${col}</th>`
      ).join('');

      // 바디
      const tbody = document.getElementById('drill-tbody');
      if (cfg.custom) {
        // 마스터 현황 표
        tbody.innerHTML = cfg.data.map(function(m) {
          var v = m.verified ? '<span class="text-xs font-bold text-green-600">인증</span>' : '<span class="text-xs text-gray-400">미인증</span>';
          var ins = m.insurance ? '<span class="text-xs font-bold text-green-600">가입</span>' : '<span class="text-xs text-gray-400">-</span>';
          var rating = m.avg_rating > 0 ? m.avg_rating + ' (' + m.review_count + ')' : '-';
          return '<tr class="hover:bg-gray-50">' +
            '<td class="px-4 py-2.5 text-sm font-semibold text-gray-900 sticky left-0 bg-white"><a href="/admin/masters/' + m.id + '" class="text-primary-600 hover:underline">' + m.name + '</a></td>' +
            '<td class="px-4 py-2.5 text-sm">' + v + '</td>' +
            '<td class="px-4 py-2.5 text-sm">' + ins + '</td>' +
            '<td class="px-4 py-2.5 text-sm text-gray-600">' + m.areas + '</td>' +
            '<td class="px-4 py-2.5 text-sm text-gray-600">' + m.experience + '년</td>' +
            '<td class="px-4 py-2.5 text-sm font-bold text-primary-700">' + m.total_jobs + '건</td>' +
            '<td class="px-4 py-2.5 text-sm font-bold text-green-600">' + m.completed + '건</td>' +
            '<td class="px-4 py-2.5 text-sm text-gray-600">' + rating + '</td>' +
            '<td class="px-4 py-2.5 text-sm text-gray-400">' + m.joined + '</td>' +
          '</tr>';
        }).join('');
      } else {
        var today = new Date();
        tbody.innerHTML = ROWS.map(function(r, idx) {
          var cells = cfg.row(r);
          var isToday = idx === 0;
          var hasData = cfg.highlights.some(function(hi) { return cells[hi] > 0; });
          var rowClass = isToday ? 'bg-primary-50' : (hasData ? 'hover:bg-gray-50' : 'hover:bg-gray-50 opacity-60');
          return '<tr class="' + rowClass + '">' +
            cells.map(function(cell, i) {
              var isHighlight = cfg.highlights.includes(i) && cell !== 0 && cell !== '₩0';
              var sticky = i === 0 ? 'sticky left-0 ' + (isToday ? 'bg-primary-50' : 'bg-white') : '';
              return '<td class="px-4 py-2.5 whitespace-nowrap text-sm ' + sticky + ' ' + (isHighlight ? 'font-bold text-primary-700' : 'text-gray-700') + ' ' + (i === 1 ? 'text-gray-400 text-xs' : '') + '">' + cell + '</td>';
            }).join('') +
          '</tr>';
        }).join('');
      }

      panel.classList.remove('hidden');
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function closeDrill() {
      activeMetric = null;
      document.getElementById('drill-panel').classList.add('hidden');
      document.querySelectorAll('[id^="card-"]').forEach(function(c) {
        c.classList.remove('border-primary-400', 'ring-2', 'ring-primary-200', 'bg-primary-50');
      });
    }

    // Turbo Drive: 페이지 로드 & 캐시 복원 시 차트 초기화
    document.addEventListener('turbo:load', function() { initCharts(); });
    // Turbo 미사용 또는 첫 로드 대응
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { initCharts(); });
    } else {
      initCharts();
    }
  </script>

  <!-- 최근 체크 + 보험청구 -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-2xl border border-gray-100">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">최근 체크</h2>
        <%= link_to "전체 보기", admin_requests_path, class: "text-sm text-primary-600 hover:text-primary-800 transition-smooth" %>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200" aria-label="최근 체크">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">번호</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">고객</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">증상</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @recent_requests.each do |request| %>
              <tr class="hover:bg-gray-50 transition-smooth">
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= link_to "##{request.id}", admin_request_path(request), class: "text-primary-600 hover:text-primary-800 font-mono text-sm" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= truncate(request.customer&.name || "-", length: 10) %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= symptom_label(request.symptom_type) %></td>
                <td class="px-6 py-4 whitespace-nowrap"><%= render "shared/status_badge", status: request.status %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">최근 보험청구</h2>
        <%= link_to "전체 보기", admin_insurance_claims_path, class: "text-sm text-primary-600 hover:text-primary-800 transition-smooth" %>
      </div>
      <div class="p-6">
        <% if @recent_insurance_claims.any? %>
          <div class="space-y-3">
            <% @recent_insurance_claims.each do |claim| %>
              <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-smooth">
                <div class="flex-1">
                  <%= link_to admin_insurance_claim_path(claim), class: "block" do %>
                    <p class="font-mono text-sm text-primary-600 hover:text-primary-800"><%= claim.claim_number %></p>
                    <p class="text-xs text-gray-600 mt-1"><%= truncate(claim.applicant_name, length: 15) %> • <%= truncate(claim.incident_address, length: 20) %></p>
                  <% end %>
                </div>
                <div class="ml-3">
                  <span class="px-2.5 py-1 rounded-full text-xs font-medium
                    <%= case claim.status
                        when 'draft', 'pending_customer_review' then 'bg-yellow-100 text-yellow-800'
                        when 'submitted', 'under_review' then 'bg-primary-100 text-primary-800'
                        when 'approved' then 'bg-green-100 text-green-800'
                        when 'rejected' then 'bg-red-100 text-red-800'
                        else 'bg-gray-100 text-gray-800'
                        end %>">
                    <%= claim.status_label %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 text-gray-500">
            <p class="text-sm">아직 보험청구가 없어요</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
