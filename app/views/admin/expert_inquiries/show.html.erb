<div class="max-w-2xl mx-auto px-4 py-8">

  <%= link_to admin_expert_inquiries_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-6 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    문의 목록
  <% end %>

  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @inquiry.name %></h1>
      <p class="text-sm text-gray-400 mt-0.5"><%= @inquiry.created_at.strftime("%Y-%m-%d %H:%M") %> 접수</p>
    </div>
    <span class="mt-1 px-3 py-1 rounded-full text-xs font-semibold
      <%= case @inquiry.status
          when 'pending'  then 'bg-amber-100 text-amber-700'
          when 'approved' then 'bg-green-100 text-green-700'
          when 'rejected' then 'bg-gray-100 text-gray-500'
          end %>">
      <%= @inquiry.status_label %>
    </span>
  </div>

  <!-- 정보 카드 -->
  <div class="bg-white border border-gray-100 rounded-2xl divide-y divide-gray-50 mb-6">
    <div class="px-5 py-4 flex justify-between">
      <span class="text-xs text-gray-400 font-semibold">이름</span>
      <span class="text-sm font-medium text-gray-900"><%= @inquiry.name %></span>
    </div>
    <div class="px-5 py-4 flex justify-between">
      <span class="text-xs text-gray-400 font-semibold">연락처</span>
      <a href="tel:<%= @inquiry.phone %>" class="text-sm font-medium text-primary-600"><%= @inquiry.phone %></a>
    </div>
    <div class="px-5 py-4 flex justify-between">
      <span class="text-xs text-gray-400 font-semibold">이메일</span>
      <span class="text-sm text-gray-700"><%= @inquiry.email.presence || "-" %></span>
    </div>
    <% if @inquiry.message.present? %>
      <div class="px-5 py-4">
        <span class="text-xs text-gray-400 font-semibold block mb-2">소개 / 문의 내용</span>
        <p class="text-sm text-gray-800 leading-relaxed whitespace-pre-line bg-gray-50 rounded-xl p-3"><%= @inquiry.message %></p>
      </div>
    <% end %>
    <% if @inquiry.respond_to?(:portfolio_url) && @inquiry.portfolio_url.present? %>
      <div class="px-5 py-4 flex justify-between items-center">
        <span class="text-xs text-gray-400 font-semibold">포트폴리오</span>
        <a href="<%= @inquiry.portfolio_url %>" target="_blank" rel="noopener"
           class="text-sm font-medium text-primary-600 hover:underline truncate max-w-[280px]"><%= @inquiry.portfolio_url %></a>
      </div>
    <% end %>
    <% if @inquiry.approval_notes.present? %>
      <div class="px-5 py-4">
        <span class="text-xs text-gray-400 font-semibold block mb-1">처리 메모</span>
        <p class="text-sm text-gray-700"><%= @inquiry.approval_notes %></p>
      </div>
    <% end %>
    <% if @inquiry.approved_at.present? %>
      <div class="px-5 py-4 flex justify-between">
        <span class="text-xs text-gray-400 font-semibold">처리 일시</span>
        <span class="text-sm text-gray-500"><%= @inquiry.approved_at.strftime("%Y-%m-%d %H:%M") %></span>
      </div>
    <% end %>
  </div>

  <!-- 액션 (검토 대기일 때만) -->
  <% if @inquiry.pending? %>
    <div class="bg-white border border-gray-100 rounded-2xl p-5 space-y-4">
      <p class="text-sm font-semibold text-gray-800">승인 / 거절 처리</p>

      <!-- 승인 폼 -->
      <%= form_with url: approve_admin_expert_inquiry_path(@inquiry), method: :post, class: "space-y-3" do |f| %>
        <div>
          <label class="block text-xs text-gray-500 mb-1">메모 <span class="text-gray-300">(선택 — 승인 이메일에 포함됨)</span></label>
          <textarea name="approval_notes" rows="2" placeholder="예) 서울 강남구 담당 구역으로 배정 예정입니다."
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-400 focus:outline-none resize-none"></textarea>
        </div>
        <button type="submit"
          class="w-full py-3 bg-primary-600 text-white text-sm font-bold rounded-xl hover:bg-primary-700 transition"
          data-confirm="승인하면 <%= @inquiry.email.present? ? "#{@inquiry.email}으로 등록 안내 이메일이 발송됩니다." : "이메일 주소가 없어 직접 연락해야 합니다." %> 계속하시겠습니까?">
          승인하고 이메일 발송
        </button>
      <% end %>

      <div class="relative flex items-center gap-2">
        <div class="flex-1 border-t border-gray-100"></div>
        <span class="text-xs text-gray-300">또는</span>
        <div class="flex-1 border-t border-gray-100"></div>
      </div>

      <!-- 거절 폼 -->
      <%= form_with url: reject_admin_expert_inquiry_path(@inquiry), method: :post, class: "space-y-3" do |f| %>
        <div>
          <label class="block text-xs text-gray-500 mb-1">거절 사유 <span class="text-gray-300">(선택 — 이메일에 포함됨)</span></label>
          <textarea name="approval_notes" rows="2" placeholder="예) 현재 해당 지역 슬롯이 가득 찼습니다."
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-gray-300 focus:outline-none resize-none"></textarea>
        </div>
        <button type="submit"
          class="w-full py-3 bg-white border border-gray-200 text-gray-600 text-sm font-semibold rounded-xl hover:bg-gray-50 transition"
          data-confirm="거절 처리하시겠습니까?">
          거절하기
        </button>
      <% end %>
    </div>

    <% unless @inquiry.email.present? %>
      <p class="mt-3 text-xs text-amber-600 text-center">
        이메일 주소가 없습니다. 승인 후 전화(<%= @inquiry.phone %>)로 직접 안내해주세요.
      </p>
    <% end %>
  <% end %>

</div>
