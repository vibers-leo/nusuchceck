<div class="max-w-3xl mx-auto px-4 py-6">
  <!-- 헤더 -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="text-xs text-gray-400"><%= @dispute.dispute_number %></p>
      <h1 class="text-xl font-bold text-gray-900"><%= @dispute.category_label %></h1>
    </div>
    <%= link_to "← 목록", admin_disputes_path, class: "text-sm text-gray-400 hover:text-gray-600" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <!-- 고객 정보 -->
    <div class="bg-white border rounded-xl p-4">
      <p class="text-xs text-gray-400 mb-1">고객 (신청자)</p>
      <p class="text-sm font-semibold"><%= @dispute.complainant.name %></p>
      <p class="text-xs text-gray-400"><%= @dispute.complainant.email %></p>
    </div>
    <!-- 전문가 정보 -->
    <div class="bg-white border rounded-xl p-4">
      <p class="text-xs text-gray-400 mb-1">전문가 (피신청자)</p>
      <p class="text-sm font-semibold"><%= @dispute.respondent.name %></p>
      <p class="text-xs text-gray-400"><%= @dispute.respondent.email %></p>
    </div>
    <!-- 금액 -->
    <div class="bg-white border rounded-xl p-4">
      <p class="text-xs text-gray-400 mb-1">분쟁 금액</p>
      <p class="text-lg font-bold text-primary-600"><%= @dispute.disputed_amount ? number_to_currency(@dispute.disputed_amount, unit: "원", format: "%n%u") : "-" %></p>
    </div>
  </div>

  <!-- 분쟁 내용 -->
  <div class="bg-white border rounded-2xl p-4 mb-4">
    <h2 class="text-sm font-bold text-gray-900 mb-2">분쟁 내용</h2>
    <p class="text-sm text-gray-700"><%= simple_format(@dispute.description) %></p>
  </div>

  <!-- 에스크로 현황 -->
  <div class="bg-white border rounded-2xl p-4 mb-4">
    <h2 class="text-sm font-bold text-gray-900 mb-3">에스크로 현황</h2>
    <% @escrows.each do |escrow| %>
      <div class="flex items-center justify-between py-2 border-b last:border-0">
        <span class="text-sm"><%= { "trip" => "🚗 출장비", "detection" => "🔍 검사비", "construction" => "🔧 공사비" }[escrow.escrow_type] %></span>
        <div class="flex items-center gap-3">
          <span class="text-sm font-semibold"><%= number_to_currency(escrow.amount, unit: "원", format: "%n%u") %></span>
          <span class="text-xs px-2 py-0.5 rounded-full
            <%= case escrow.status
                when 'held' then 'bg-yellow-100 text-yellow-700'
                when 'deposited' then 'bg-blue-100 text-blue-700'
                when 'refunded' then 'bg-red-100 text-red-600'
                when 'released', 'settled' then 'bg-green-100 text-green-700'
                else 'bg-gray-100 text-gray-500'
                end %>">
            <%= escrow.status %>
          </span>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 대화 내역 -->
  <div class="bg-white border rounded-2xl p-4 mb-4">
    <h2 class="text-sm font-bold text-gray-900 mb-3">대화 내역</h2>
    <div class="space-y-3 max-h-80 overflow-y-auto">
      <% @messages.each do |msg| %>
        <div class="flex gap-2">
          <span class="text-xs font-semibold text-gray-500 w-16 shrink-0 pt-1">
            <%= msg.sender_role == "customer" ? "고객" : msg.sender_role == "expert" ? "전문가" : msg.sender_role == "mediator" ? "중재자" : "시스템" %>
          </span>
          <div class="flex-1">
            <p class="text-sm text-gray-700 bg-gray-50 rounded-lg px-3 py-2"><%= msg.content %></p>
            <p class="text-[10px] text-gray-400 mt-1"><%= msg.created_at.strftime("%m/%d %H:%M") %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 중재자 메시지 -->
  <% unless @dispute.resolved? || @dispute.auto_resolved? || @dispute.cancelled? %>
    <%= form_with url: add_message_admin_dispute_path(@dispute), method: :post, class: "flex gap-2 mb-6" do %>
      <%= text_field_tag :content, nil, placeholder: "중재자 메시지...", class: "flex-1 border border-gray-300 rounded-xl px-4 py-2 text-sm" %>
      <%= submit_tag "전송", class: "bg-gray-700 text-white px-4 py-2 rounded-xl text-sm cursor-pointer" %>
    <% end %>

    <!-- 중재 액션 -->
    <div class="bg-gray-50 border rounded-2xl p-4">
      <h2 class="text-sm font-bold text-gray-900 mb-4">중재 결정</h2>

      <% unless @dispute.mediation? %>
        <%= link_to "중재 시작", start_mediation_admin_dispute_path(@dispute), method: :post, class: "bg-blue-500 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-blue-600 mr-2" %>
      <% end %>

      <%= form_with url: resolve_admin_dispute_path(@dispute), method: :post, class: "mt-4 space-y-3" do %>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1">결정 유형</label>
          <select name="resolution_type" class="w-full border rounded-xl px-3 py-2 text-sm">
            <% Dispute::RESOLUTION_TYPES.each do |key, label| %>
              <option value="<%= key %>"><%= label %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1">환불 비율 (%)</label>
          <input type="number" name="refund_percentage" min="0" max="100" placeholder="부분 환불 시 입력" class="w-full border rounded-xl px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1">결정 사유</label>
          <textarea name="resolution_note" rows="3" placeholder="중재 결정 사유를 작성하세요..." class="w-full border rounded-xl px-3 py-2 text-sm resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-red-500 text-white py-2 rounded-xl text-sm font-semibold hover:bg-red-600" data-confirm="정말 결정을 확정할까요?">중재 결정 확정</button>
      <% end %>
    </div>
  <% else %>
    <!-- 결정 결과 -->
    <div class="bg-green-50 border border-green-200 rounded-2xl p-4">
      <h2 class="text-sm font-bold text-green-800 mb-2">중재 결정 완료</h2>
      <p class="text-sm text-green-700"><strong><%= @dispute.resolution_label %></strong> <%= @dispute.refund_percentage ? "(#{@dispute.refund_percentage}%)" : "" %></p>
      <p class="text-sm text-green-600 mt-1"><%= @dispute.resolution_note %></p>
      <p class="text-xs text-green-400 mt-2">결정일: <%= @dispute.resolved_at&.strftime("%Y-%m-%d %H:%M") %></p>
    </div>
  <% end %>
</div>
