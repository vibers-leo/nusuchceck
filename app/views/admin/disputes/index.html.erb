<div class="max-w-5xl mx-auto px-4 py-6">
  <h1 class="text-xl font-bold text-gray-900 mb-6">분쟁 관리</h1>

  <!-- 통계 -->
  <div class="grid grid-cols-4 gap-3 mb-6">
    <div class="bg-white border rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-gray-900"><%= @stats[:total] %></p>
      <p class="text-xs text-gray-400">전체</p>
    </div>
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-yellow-600"><%= @stats[:opened] %></p>
      <p class="text-xs text-yellow-600">진행 중</p>
    </div>
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-blue-600"><%= @stats[:mediation] %></p>
      <p class="text-xs text-blue-600">중재 중</p>
    </div>
    <div class="bg-green-50 border border-green-200 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-green-600"><%= @stats[:resolved] %></p>
      <p class="text-xs text-green-600">해결</p>
    </div>
  </div>

  <!-- 목록 -->
  <div class="bg-white border rounded-2xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs text-gray-500">번호</th>
          <th class="px-4 py-3 text-left text-xs text-gray-500">유형</th>
          <th class="px-4 py-3 text-left text-xs text-gray-500">고객</th>
          <th class="px-4 py-3 text-left text-xs text-gray-500">전문가</th>
          <th class="px-4 py-3 text-left text-xs text-gray-500">금액</th>
          <th class="px-4 py-3 text-left text-xs text-gray-500">상태</th>
          <th class="px-4 py-3 text-left text-xs text-gray-500">접수일</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @disputes.each do |dispute| %>
          <tr class="hover:bg-gray-50 cursor-pointer" onclick="location.href='<%= admin_dispute_path(dispute) %>'">
            <td class="px-4 py-3 text-xs text-gray-400"><%= dispute.dispute_number %></td>
            <td class="px-4 py-3 font-medium"><%= dispute.category_label %></td>
            <td class="px-4 py-3"><%= dispute.complainant.name %></td>
            <td class="px-4 py-3"><%= dispute.respondent.name %></td>
            <td class="px-4 py-3 font-semibold"><%= dispute.disputed_amount ? number_to_currency(dispute.disputed_amount, unit: "원", format: "%n%u") : "-" %></td>
            <td class="px-4 py-3">
              <span class="text-xs px-2 py-0.5 rounded-full
                <%= case dispute.status
                    when 'opened', 'expert_response' then 'bg-yellow-100 text-yellow-700'
                    when 'mediation' then 'bg-blue-100 text-blue-700'
                    when 'resolved', 'auto_resolved' then 'bg-green-100 text-green-700'
                    when 'cancelled' then 'bg-gray-100 text-gray-500'
                    end %>">
                <%= { 'opened' => '접수', 'expert_response' => '답변대기', 'mediation' => '중재중', 'resolved' => '해결', 'auto_resolved' => '자동해결', 'cancelled' => '취소' }[dispute.status] %>
              </span>
            </td>
            <td class="px-4 py-3 text-xs text-gray-400"><%= dispute.created_at.strftime("%m/%d %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @disputes.empty? %>
      <p class="text-center text-gray-400 text-sm py-12">분쟁 내역이 없어요</p>
    <% end %>
  </div>
</div>
