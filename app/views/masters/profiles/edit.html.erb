<div class="max-w-2xl mx-auto">
  <%= render "shared/page_header",
      title: "프로필 수정",
      back_path: masters_profile_path,
      back_text: "프로필로 돌아가기" %>

  <div class="bg-white rounded-2xl border border-gray-100 p-6">
    <%= form_with(model: @profile, url: masters_profile_path, method: :patch, class: "space-y-6",
                  data: { controller: "form-validation", action: "submit->form-validation#submit" }) do |f| %>

      <%= render "shared/form_errors", resource: @profile %>

      <!-- 자격증 번호 -->
      <div>
        <%= f.label :license_number, "자격증 번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :license_number,
              placeholder: "누수탐지 자격증 번호",
              class: input_classes(:text),
              data: { action: "blur->form-validation#validate" } %>
      </div>

      <!-- 경력 -->
      <div>
        <%= f.label :experience_years, "경력 (년)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :experience_years,
              min: 0, max: 50, step: 1,
              class: input_classes(:text) %>
      </div>

      <!-- 보유 장비 -->
      <div>
        <%= f.label :equipment, "보유 장비", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :equipment,
              value: @profile.equipment_list.join(", "),
              placeholder: "열화상카메라, 청음기, 수분측정기 (콤마로 구분)",
              class: input_classes(:text) %>
        <p class="mt-1 text-xs text-gray-500">콤마(,)로 구분하여 입력해 주세요.</p>
      </div>

      <!-- 서비스 지역 -->
      <div>
        <%= f.label :service_areas, "서비스 지역", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :service_areas,
              value: @profile.service_areas_list.join(", "),
              placeholder: "서울 강남구, 서울 서초구, 경기 성남시 (콤마로 구분)",
              class: input_classes(:text) %>
        <p class="mt-1 text-xs text-gray-500">콤마(,)로 구분하여 입력해 주세요.</p>
      </div>

      <hr class="border-gray-200">

      <!-- 계좌 정보 -->
      <h3 class="text-lg font-semibold text-gray-900">계좌 정보</h3>

      <div class="space-y-4">
        <!-- 은행 선택 -->
        <div data-controller="button-select">
          <%= f.label :bank_name, "은행", class: "block text-sm font-medium text-gray-700 mb-3" %>

          <%= f.hidden_field :bank_name, id: "bank-name-input" %>

          <div class="grid grid-cols-3 sm:grid-cols-4 gap-2">
            <% [
              "국민은행", "신한은행", "우리은행", "하나은행",
              "농협은행", "기업은행", "카카오뱅크", "토스뱅크",
              "SC제일은행", "대구은행", "부산은행", "경남은행"
            ].each do |bank| %>
              <button type="button"
                      class="select-button relative px-3 py-2.5 rounded-lg border-2 border-gray-200 hover:border-primary-400 hover:bg-primary-50 transition-all text-center <%= 'border-primary-600 bg-primary-50 selected' if @profile.bank_name == bank %>"
                      data-action="click->button-select#select"
                      data-field="bank-name"
                      data-value="<%= bank %>"
                      role="radio"
                      aria-checked="<%= @profile.bank_name == bank ? 'true' : 'false' %>">
                <div class="select-check <%= 'hidden' unless @profile.bank_name == bank %> absolute top-1 right-1">
                  <svg class="w-4 h-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <p class="font-medium text-sm text-gray-900"><%= bank %></p>
              </button>
            <% end %>
          </div>
        </div>

        <!-- 계좌번호 및 예금주 -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :account_number, "계좌번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :account_number,
                  placeholder: "계좌번호",
                  class: input_classes(:text) %>
          </div>
          <div>
            <%= f.label :account_holder, "예금주", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :account_holder,
                  placeholder: "예금주명",
                  class: input_classes(:text) %>
          </div>
        </div>
      </div>

      <hr class="border-gray-200">

      <!-- 자기소개 -->
      <div>
        <%= f.label :bio, "자기소개", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :bio,
              rows: 5,
              placeholder: "경력, 전문 분야, 특기 사항 등을 자유롭게 작성해 주세요.",
              class: input_classes(:textarea) %>
      </div>

      <!-- 제출 버튼 -->
      <div class="flex items-center justify-end gap-3 pt-4 border-t">
        <%= link_to "취소", masters_profile_path, class: btn_classes(:secondary, :md) %>
        <%= f.submit "저장", class: btn_classes(:primary, :md) %>
      </div>
    <% end %>
  </div>

  <!-- 배상책임보험 인증 카드 (별도 폼) -->
  <div class="bg-white rounded-2xl border border-gray-100 p-6 mt-4">
    <div class="flex items-start gap-3 mb-5">
      <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
      </div>
      <div>
        <h2 class="text-sm font-bold text-gray-900">배상책임보험 인증</h2>
        <p class="text-xs text-gray-500 mt-0.5">보험가입증명서를 업로드하면 자동 인식 후 검토 완료돼요. 인증된 전문가에게는 프로필에 뱃지가 표시돼요.</p>
      </div>
    </div>

    <!-- 현재 인증 상태 -->
    <% if @profile.insurance_active? %>
      <div class="flex items-center gap-2 p-3 bg-green-50 rounded-xl mb-4">
        <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-green-700">인증 완료</p>
          <p class="text-xs text-green-600">
            <%= @profile.insurance_insurer_name.presence || "보험사" %>
            <% if @profile.insurance_valid_until %>
              · 만기 <%= @profile.insurance_valid_until.strftime("%Y.%m.%d") %>
            <% end %>
          </p>
        </div>
        <% if @profile.insurance_expiring_soon? %>
          <span class="ml-auto text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full">만기 임박</span>
        <% end %>
      </div>
    <% elsif @profile.insurance_pending_review? %>
      <div class="flex items-center gap-2 p-3 bg-amber-50 rounded-xl mb-4">
        <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm font-semibold text-amber-700">검토 중 — 관리자 확인 후 인증 완료돼요</p>
      </div>
    <% else %>
      <div class="flex items-center gap-2 p-3 bg-gray-50 rounded-xl mb-4">
        <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <p class="text-sm text-gray-600">아직 보험 인증이 완료되지 않았어요</p>
      </div>
    <% end %>

    <!-- 업로드 폼 -->
    <%= form_with url: upload_insurance_masters_profile_path, method: :post, multipart: true do |uf| %>
      <div class="border-2 border-dashed border-gray-200 rounded-xl p-5 text-center hover:border-primary-300 transition-colors">
        <svg class="w-8 h-8 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p class="text-sm font-semibold text-gray-600 mb-1">보험가입증명서 업로드</p>
        <p class="text-xs text-gray-400 mb-3">JPG, PNG, PDF 지원 · OCR로 자동 인식돼요</p>
        <%= uf.file_field :insurance_certificate,
              accept: "image/*,.pdf",
              class: "hidden",
              id: "insurance_cert_input",
              data: { action: "change->insurance-upload#preview" } %>
        <label for="insurance_cert_input"
               class="inline-flex items-center gap-2 px-4 py-2 bg-primary-50 text-primary-700 text-sm font-semibold rounded-xl cursor-pointer hover:bg-primary-100 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
          파일 선택
        </label>
      </div>

      <div id="insurance_file_name" class="mt-2 text-xs text-gray-500 text-center hidden"></div>

      <div class="mt-3">
        <%= uf.submit "제출 및 인증 요청",
              class: "w-full py-3 rounded-xl bg-primary-600 text-white text-sm font-bold hover:bg-primary-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <p class="text-xs text-gray-400 mt-3 text-center">
      제출된 서류는 안전하게 암호화 저장되며, 인증 목적으로만 사용돼요
    </p>
  </div>
</div>

<script>
  document.getElementById('insurance_cert_input')?.addEventListener('change', function() {
    const name = this.files[0]?.name
    const el = document.getElementById('insurance_file_name')
    if (name && el) { el.textContent = name; el.classList.remove('hidden') }
  })
</script>
