<% content_for :title, "전문가 등록 마스터 플랜 시작" %>

<div class="min-h-screen bg-gray-50 py-10">
  <div class="max-w-lg mx-auto px-4">

    <!-- 헤더 -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 rounded-2xl mb-4">
        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">전문가 등록 마스터 플랜</h1>
      <p class="text-gray-500 mt-2">내 구역 고객에게 가장 먼저 노출돼요</p>
    </div>

    <!-- 플랜 혜택 카드 -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <span class="text-lg font-bold text-gray-900">전문가 등록 마스터 플랜</span>
        <div class="text-right">
          <span class="text-2xl font-bold text-blue-600">99,000원</span>
          <span class="text-sm text-gray-400">/월</span>
        </div>
      </div>

      <ul class="space-y-3">
        <% [
          ["구역 우선 노출", "선택 구역 고객에게 1순위로 노출", true],
          ["우선 매칭 알림", "신규 체크 접수 시 가장 먼저 알림", true],
          ["무제한 견적 제출", "월 건수 제한 없이 모든 요청에 견적", true],
          ["자동 갱신", "매월 자동결제로 구독 유지", true],
          ["언제든 해지", "위약금 없이 즉시 해지 가능", true],
        ].each do |title, desc, included| %>
          <li class="flex items-start gap-3">
            <div class="flex-shrink-0 w-5 h-5 rounded-full bg-blue-100 flex items-center justify-center mt-0.5">
              <svg class="w-3 h-3 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900"><%= title %></p>
              <p class="text-xs text-gray-500"><%= desc %></p>
            </div>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- 약관 동의 + 결제 버튼 -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4">
      <div class="bg-amber-50 rounded-xl p-4 mb-5 text-xs text-amber-800 space-y-1">
        <p class="font-semibold">자동결제 안내</p>
        <p>카드 등록 즉시 <strong>99,000원</strong>이 결제되고, 이후 매월 같은 날 자동 갱신됩니다.</p>
        <p>해지는 결제 관리 페이지에서 언제든 가능하며, 이미 결제된 금액은 환불되지 않습니다.</p>
      </div>

      <!-- 약관 동의 체크박스 -->
      <div class="space-y-2.5 mb-5">
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" id="agree-terms" class="w-4 h-4 mt-0.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
          <span class="text-sm text-gray-700">
            <a href="<%= terms_path %>" target="_blank" class="text-blue-600 underline font-semibold">서비스 이용약관</a>에 동의합니다 <span class="text-red-500 font-bold">(필수)</span>
          </span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" id="agree-refund" class="w-4 h-4 mt-0.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
          <span class="text-sm text-gray-700">
            <a href="<%= refund_path %>" target="_blank" class="text-blue-600 underline font-semibold">취소 및 환불 정책</a>에 동의합니다 <span class="text-red-500 font-bold">(필수)</span>
          </span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" id="agree-auto" class="w-4 h-4 mt-0.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
          <span class="text-sm text-gray-700">
            매월 99,000원의 <strong>자동결제</strong>에 동의합니다 <span class="text-red-500 font-bold">(필수)</span>
          </span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" id="agree-privacy" class="w-4 h-4 mt-0.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500 flex-shrink-0">
          <span class="text-sm text-gray-700">
            결제 처리를 위한 개인정보 제3자 제공 (토스페이먼츠)에 동의합니다 <span class="text-red-500 font-bold">(필수)</span>
          </span>
        </label>
      </div>

      <!-- 전체 동의 체크박스 -->
      <label class="flex items-center gap-3 cursor-pointer py-3 border-t border-gray-100 mb-5">
        <input type="checkbox" id="agree-all" class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
        <span class="text-sm font-bold text-gray-900">위 내용에 모두 동의합니다</span>
      </label>

      <button id="toss-payment-btn"
              data-customer-key="<%= @customer_key %>"
              data-success-url="<%= @success_url %>"
              data-fail-url="<%= @fail_url %>"
              data-client-key="<%= @toss_client_key %>"
              disabled
              class="w-full bg-blue-600 text-white font-bold py-4 px-6 rounded-xl text-lg disabled:opacity-40 disabled:cursor-not-allowed transition-all hover:enabled:bg-blue-700">
        카드 등록하고 시작하기
      </button>
    </div>

    <!-- 안내 -->
    <div class="text-center space-y-1">
      <p class="text-xs text-gray-400">토스페이먼츠 · 안전한 결제</p>
      <p class="text-xs text-gray-400">
        문의:
        <a href="mailto:contact@nusucheck.com" class="underline">contact@nusucheck.com</a>
      </p>
    </div>

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const btn        = document.getElementById('toss-payment-btn');
  const agreeAll   = document.getElementById('agree-all');
  const required   = ['agree-terms', 'agree-refund', 'agree-auto', 'agree-privacy'];

  if (!btn) return;

  // 필수 체크박스 모두 체크됐는지 확인 → 버튼 활성화
  function updateBtn() {
    const allChecked = required.every(id => document.getElementById(id)?.checked);
    btn.disabled = !allChecked;
  }

  // 전체 동의 체크 시 개별 항목 모두 체크/해제
  agreeAll?.addEventListener('change', function() {
    required.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.checked = this.checked;
    });
    updateBtn();
  });

  // 개별 항목 변경 시 전체 동의 상태 반영
  required.forEach(id => {
    document.getElementById(id)?.addEventListener('change', function() {
      const allChecked = required.every(i => document.getElementById(i)?.checked);
      if (agreeAll) agreeAll.checked = allChecked;
      updateBtn();
    });
  });

  // 결제 버튼 클릭
  btn.addEventListener('click', async function() {
    btn.disabled = true;
    btn.textContent = '결제창 열기...';

    try {
      const { loadTossPayments } = await import('https://js.tosspayments.com/v2/standard');
      const tossPayments = await loadTossPayments(btn.dataset.clientKey);
      const payment = tossPayments.payment({ customerKey: btn.dataset.customerKey });

      await payment.requestBillingAuth({
        method: 'CARD',
        successUrl: btn.dataset.successUrl,
        failUrl:    btn.dataset.failUrl,
        customerEmail: '<%= current_user.email %>',
        customerName:  '<%= current_user.name %>',
      });
    } catch(e) {
      console.error(e);
      btn.disabled = false;
      btn.textContent = '카드 등록하고 시작하기';
    }
  });
});
</script>
