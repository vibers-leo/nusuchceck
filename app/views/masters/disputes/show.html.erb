<div class="max-w-2xl mx-auto px-4 py-6">
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="text-xs text-gray-400"><%= @dispute.dispute_number %></p>
      <h1 class="text-xl font-bold text-gray-900"><%= @dispute.category_label %></h1>
    </div>
    <%= link_to "← 목록", masters_disputes_path, class: "text-sm text-gray-400" %>
  </div>

  <!-- 기한 경고 -->
  <% if @dispute.overdue? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-3 mb-4">
      <p class="text-sm text-red-700 font-semibold">답변 기한이 초과됐어요. 빠르게 답변해 주세요!</p>
    </div>
  <% elsif @dispute.opened? && @dispute.expert_response_deadline.present? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-3 mb-4">
      <p class="text-xs text-yellow-700">답변 기한: <strong><%= @dispute.expert_response_deadline.strftime("%m/%d %H:%M") %></strong>까지</p>
    </div>
  <% end %>

  <!-- 분쟁 내용 -->
  <div class="bg-white border rounded-2xl p-4 mb-4">
    <p class="text-xs text-gray-400 mb-1">고객 주장</p>
    <p class="text-sm text-gray-700"><%= simple_format(@dispute.description) %></p>
  </div>

  <!-- 대화 내역 -->
  <div class="bg-white border rounded-2xl p-4 mb-4">
    <h2 class="text-sm font-bold text-gray-900 mb-3">대화 내역</h2>
    <div class="space-y-3 max-h-80 overflow-y-auto">
      <% @messages.each do |msg| %>
        <div class="<%= msg.system? ? 'text-center' : (msg.sender_id == current_user.id ? 'text-right' : 'text-left') %>">
          <% if msg.system? %>
            <p class="text-xs text-gray-400 bg-gray-50 rounded-lg px-3 py-2 inline-block"><%= msg.content %></p>
          <% else %>
            <p class="text-xs text-gray-500 mb-1"><%= msg.sender_name %></p>
            <div class="inline-block max-w-xs px-4 py-2 rounded-2xl text-sm
              <%= msg.sender_id == current_user.id ? 'bg-primary-500 text-white' : 'bg-gray-100 text-gray-800' %>">
              <%= simple_format(msg.content) %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 답변 입력 -->
  <% unless @dispute.resolved? || @dispute.auto_resolved? || @dispute.cancelled? %>
    <%= form_with url: respond_masters_dispute_path(@dispute), method: :post, class: "space-y-3" do %>
      <textarea name="content" rows="3" placeholder="답변을 작성하세요. 합의안이 있으면 제안해 주세요." class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm resize-none focus:ring-2 focus:ring-primary-500"></textarea>
      <button type="submit" class="w-full bg-primary-500 text-white py-3 rounded-xl text-sm font-semibold hover:bg-primary-600">답변 보내기</button>
    <% end %>
  <% end %>

  <!-- 결정 결과 -->
  <% if @dispute.resolved? || @dispute.auto_resolved? %>
    <div class="bg-green-50 border border-green-200 rounded-2xl p-4 mt-4">
      <p class="text-sm font-bold text-green-800"><%= @dispute.resolution_label %></p>
      <p class="text-sm text-green-700 mt-1"><%= @dispute.resolution_note %></p>
    </div>
  <% end %>
</div>
