<div class="space-y-6 py-8">
  <!-- 헤더 -->
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">내 작업 목록</h1>
    <p class="mt-2 text-gray-600">진행 중인 작업을 확인하고 관리하세요</p>
  </div>

  <!-- 미승인 전문가 안내 -->
  <% unless current_user.master_profile&.verified? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-5 mb-6">
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 text-yellow-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <div class="flex-1">
          <h3 class="text-yellow-900 font-semibold mb-1">승인 대기 중</h3>
          <p class="text-sm text-yellow-800 mb-2">
            관리자가 프로필을 검토 중입니다. 승인이 완료되면 공개 오더를 선택할 수 있어요.
          </p>
          <%= link_to "프로필 완성하기", edit_masters_profile_path,
                class: "inline-block text-sm font-medium text-yellow-900 underline hover:text-yellow-700 transition" %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- 탭 네비게이션 -->
  <div class="flex border-b border-gray-200 mb-6">
    <span class="px-4 py-2 text-sm font-medium text-blue-700 border-b-2 border-blue-500">
      내 진행 중 작업
    </span>
    <%= link_to open_orders_masters_requests_path, class: "px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-300 transition-colors flex items-center" do %>
      공개 오더
      <% if @open_count.to_i > 0 %>
        <span class="ml-1.5 inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold bg-red-500 text-white rounded-full animate-pulse">
          <%= @open_count %>
        </span>
      <% end %>
    <% end %>
  </div>

  <!-- 검색/필터 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
    <%= search_form_for @q, url: masters_requests_path, html: { method: :get, class: "flex flex-col sm:flex-row gap-3" } do |f| %>
      <div class="flex-1">
        <%= f.select :status_eq,
              options_for_select([
                ["전체 상태", ""],
                ["마스터 배정", "assigned"],
                ["방문 중", "visiting"],
                ["탐지 중", "detecting"],
                ["누수 미확인", "no_leak_found"],
                ["견적 대기", "estimate_pending"],
                ["견적 제출", "estimate_submitted"],
                ["공사 합의", "construction_agreed"],
                ["에스크로 입금", "escrow_deposited"],
                ["공사 진행", "constructing"],
                ["공사 완료", "construction_completed"],
                ["종료", "closed"],
                ["취소", "cancelled"]
              ], params.dig(:q, :status_eq)),
              {}, class: input_classes(:select) %>
      </div>
      <div class="flex-1">
        <%= f.select :symptom_type_eq,
              options_for_select([
                ["전체 증상", ""],
                ["벽면 누수", "wall_leak"],
                ["천장 누수", "ceiling_leak"],
                ["바닥 누수", "floor_leak"],
                ["배관 누수", "pipe_leak"],
                ["화장실 누수", "toilet_leak"],
                ["외부 누수", "outdoor_leak"]
              ], params.dig(:q, :symptom_type_eq)),
              {}, class: input_classes(:select) %>
      </div>
      <div class="flex gap-2">
        <%= f.submit "검색", class: btn_classes(:primary, :md) %>
        <%= link_to "초기화", masters_requests_path, class: btn_classes(:secondary, :md) %>
      </div>
    <% end %>
  </div>

  <!-- 카드형 목록 -->
  <% if @requests.any? %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @requests.each do |request| %>
        <%= link_to masters_request_path(request), class: "block bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition" do %>
          <div class="p-5">
            <div class="flex items-center justify-between mb-3">
              <span class="text-sm font-mono text-gray-500">#<%= request.id %></span>
              <%= render "shared/status_badge", status: request.status %>
            </div>

            <h3 class="font-semibold text-gray-900 mb-1">
              <%= request.customer&.name || "고객" %>
            </h3>

            <p class="text-sm text-blue-600 font-medium mb-2"><%= symptom_label(request.symptom_type) %></p>

            <div class="space-y-1 text-sm text-gray-600">
              <p class="flex items-center">
                <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <%= truncate(request.address, length: 30) %>
              </p>
              <% if request.assigned_at.present? %>
                <p class="flex items-center">
                  <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  배정일: <%= request.assigned_at.strftime("%Y-%m-%d %H:%M") %>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- 페이지네이션 -->
    <div class="mt-6">
      <%= paginate @requests %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
          icon: "document",
          title: "현재 배정된 작업이 없어요",
          description: "새로운 누수 신고가 배정되면 바로 알려드릴게요" %>

    <!-- 대기 중 안내 -->
    <div class="mt-8 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 border border-blue-100">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">⏱️</span>
        <h3 class="font-bold text-gray-900">잠시만 기다려주세요</h3>
      </div>
      <div class="space-y-3 text-sm text-gray-700">
        <p>새로운 누수 신고가 들어오면 <strong>즉시 알림</strong>을 보내드려요</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4 pt-4 border-t border-blue-200">
          <div>
            <p class="font-semibold text-gray-900 mb-1">📍 내 지역 우선</p>
            <p class="text-gray-600 text-xs">가까운 곳부터 배정돼요</p>
          </div>
          <div>
            <p class="font-semibold text-gray-900 mb-1">⚡ 빠른 매칭</p>
            <p class="text-gray-600 text-xs">실시간으로 매칭돼요</p>
          </div>
          <div>
            <p class="font-semibold text-gray-900 mb-1">💰 투명한 수익</p>
            <p class="text-gray-600 text-xs">에스크로로 안전하게</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 작업 준비 팁 -->
    <div class="mt-6 bg-gradient-to-br from-yellow-50 to-amber-50 rounded-2xl p-6 border border-yellow-100">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">💡</span>
        <h3 class="font-bold text-gray-900">신고가 배정되면 이렇게 준비하세요</h3>
      </div>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-6 h-6 bg-yellow-500 text-white rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <span>고객 정보와 주소를 확인하세요</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-6 h-6 bg-yellow-500 text-white rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <span>방문 시간을 협의하고 준비물을 챙기세요</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-6 h-6 bg-yellow-500 text-white rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <span>현장에서 정확히 진단하고 견적을 제시하세요</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-6 h-6 bg-yellow-500 text-white rounded-full flex items-center justify-center text-xs font-bold">4</span>
          <span>작업 완료 후 에스크로로 안전하게 대금을 받으세요</span>
        </li>
      </ul>
    </div>
  <% end %>
</div>
