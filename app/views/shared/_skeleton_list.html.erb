<%# 당근마켓 스타일 스켈레톤 로딩 리스트 %>
<% count = local_assigns[:count] || 3 %>
<div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
  <% count.times do %>
    <div class="px-4 py-4 animate-pulse">
      <div class="flex items-start gap-3">
        <div class="w-12 h-12 skeleton rounded-xl flex-shrink-0"></div>
        <div class="flex-1 space-y-2 pt-1">
          <div class="h-3.5 skeleton w-2/3"></div>
          <div class="h-3 skeleton w-1/2"></div>
          <div class="h-2.5 skeleton w-1/3"></div>
        </div>
      </div>
    </div>
  <% end %>
</div>
