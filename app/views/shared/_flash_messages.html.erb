<%# 당근마켓 스타일 토스트 알림 - 하단 표시 %>
<% if notice.present? %>
  <div class="fixed bottom-20 md:bottom-6 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-sm"
       data-controller="dismissible" data-action="click->dismissible#dismiss">
    <div class="bg-gray-900 text-white px-4 py-3 rounded-2xl flex items-center justify-between shadow-lg flash-message" role="alert" aria-live="polite">
      <div class="flex items-center">
        <svg class="w-5 h-5 text-green-400 mr-2.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="text-sm font-medium"><%= notice %></span>
      </div>
      <button type="button" class="text-gray-400 hover:text-white ml-3 flex-shrink-0" aria-label="닫기">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
<% end %>

<% if alert.present? %>
  <div class="fixed bottom-20 md:bottom-6 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-sm"
       data-controller="dismissible" data-action="click->dismissible#dismiss">
    <div class="bg-red-600 text-white px-4 py-3 rounded-2xl flex items-center justify-between shadow-lg flash-message" role="alert" aria-live="assertive">
      <div class="flex items-center">
        <svg class="w-5 h-5 text-red-200 mr-2.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <span class="text-sm font-medium"><%= alert %></span>
      </div>
      <button type="button" class="text-red-200 hover:text-white ml-3 flex-shrink-0" aria-label="닫기">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
<% end %>
