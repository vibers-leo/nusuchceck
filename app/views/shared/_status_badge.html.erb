<%# 당근마켓 스타일 상태 뱃지 - pill 형태 %>
<%
  badge_colors = {
    "reported"               => "bg-gray-100 text-gray-700",
    "assigned"               => "bg-primary-50 text-primary-700",
    "visiting"               => "bg-primary-100 text-primary-700",
    "detecting"              => "bg-amber-50 text-amber-700",
    "no_leak_found"          => "bg-gray-100 text-gray-600",
    "estimate_pending"       => "bg-primary-50 text-primary-700",
    "estimate_submitted"     => "bg-primary-100 text-primary-700",
    "construction_agreed"    => "bg-primary-100 text-primary-800",
    "escrow_deposited"       => "bg-primary-50 text-primary-700",
    "constructing"           => "bg-violet-50 text-violet-700",
    "construction_completed" => "bg-green-50 text-green-700",
    "closed"                 => "bg-green-100 text-green-800",
    "cancelled"              => "bg-red-50 text-red-600"
  }

  status_labels = {
    "reported"               => "접수됨",
    "assigned"               => "마스터 배정",
    "visiting"               => "방문 중",
    "detecting"              => "탐지 중",
    "no_leak_found"          => "누수 미확인",
    "estimate_pending"       => "견적 대기",
    "estimate_submitted"     => "견적 제출",
    "construction_agreed"    => "공사 합의",
    "escrow_deposited"       => "에스크로 입금",
    "constructing"           => "공사 진행",
    "construction_completed" => "공사 완료",
    "closed"                 => "종료",
    "cancelled"              => "취소"
  }

  css_class = badge_colors[status.to_s] || "bg-gray-100 text-gray-700"
  label = status_labels[status.to_s] || status.to_s.humanize
%>
<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= css_class %>" role="status" aria-label="상태: <%= label %>">
  <%= label %>
</span>
