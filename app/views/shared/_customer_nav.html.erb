<!-- 고객 앱 하단 네비게이션 (당근마켓 스타일) -->
<nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-50 md:hidden">
  <div class="flex items-center justify-around h-16">
    <!-- 홈 -->
    <%= link_to customers_dashboard_path, class: "flex flex-col items-center justify-center flex-1 h-full #{request.path == customers_dashboard_path ? 'text-primary-600' : 'text-gray-500'} hover:text-primary-600 transition-colors" do %>
      <svg class="w-6 h-6 mb-1" fill="<%= request.path == customers_dashboard_path ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      <span class="text-xs font-medium">홈</span>
    <% end %>

    <!-- 내 요청 -->
    <%= link_to customers_requests_path, class: "flex flex-col items-center justify-center flex-1 h-full #{request.path == customers_requests_path ? 'text-primary-600' : 'text-gray-500'} hover:text-primary-600 transition-colors" do %>
      <svg class="w-6 h-6 mb-1" fill="<%= request.path == customers_requests_path ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <span class="text-xs font-medium">내 요청</span>
    <% end %>

    <!-- 체크 시작 (중앙 강조) -->
    <%= link_to new_customers_request_path, class: "flex flex-col items-center justify-center flex-1 h-full relative" do %>
      <div class="absolute -top-4 w-14 h-14 bg-gradient-to-r from-primary-600 to-purple-600 rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all">
        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
        </svg>
      </div>
      <span class="text-xs font-medium text-gray-500 mt-7">체크하기</span>
    <% end %>

    <!-- 보험청구 -->
    <%= link_to customers_insurance_claims_path, class: "flex flex-col items-center justify-center flex-1 h-full #{request.path.start_with?('/customers/insurance_claims') ? 'text-primary-600' : 'text-gray-500'} hover:text-primary-600 transition-colors" do %>
      <svg class="w-6 h-6 mb-1" fill="<%= request.path.start_with?('/customers/insurance_claims') ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <span class="text-xs font-medium">보험</span>
    <% end %>

    <!-- 내 정보 -->
    <%= link_to customers_profile_path, class: "flex flex-col items-center justify-center flex-1 h-full #{request.path == customers_profile_path ? 'text-primary-600' : 'text-gray-500'} hover:text-primary-600 transition-colors" do %>
      <svg class="w-6 h-6 mb-1" fill="<%= request.path == customers_profile_path ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      <span class="text-xs font-medium">내 정보</span>
    <% end %>
  </div>
</nav>

<!-- 데스크톱용 상단 네비게이션 -->
<nav class="hidden md:block bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- 로고 -->
      <%= link_to customers_dashboard_path, class: "flex items-center gap-2 font-bold text-xl text-gray-900 hover:text-primary-600 transition-colors" do %>
        <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
        </svg>
        <span>누수체크</span>
      <% end %>

      <!-- 메뉴 -->
      <div class="flex items-center gap-8">
        <%= link_to "홈", customers_dashboard_path, class: "text-gray-700 hover:text-primary-600 font-medium transition-colors #{request.path == customers_dashboard_path ? 'text-primary-600' : ''}" %>
        <%= link_to "서비스 소개", how_it_works_path, class: "text-gray-700 hover:text-primary-600 font-medium transition-colors #{request.path == how_it_works_path ? 'text-primary-600' : ''}" %>
        <%= link_to "전문가", customers_masters_path, class: "text-gray-700 hover:text-primary-600 font-medium transition-colors #{request.path == customers_masters_path ? 'text-primary-600' : ''}" %>
        <%= link_to "내 요청", customers_requests_path, class: "text-gray-700 hover:text-primary-600 font-medium transition-colors #{request.path == customers_requests_path ? 'text-primary-600' : ''}" %>
        <%= link_to "보험청구", customers_insurance_claims_path, class: "text-gray-700 hover:text-primary-600 font-medium transition-colors #{request.path.start_with?('/customers/insurance_claims') ? 'text-primary-600' : ''}" %>

        <!-- CTA 버튼 -->
        <%= link_to new_customers_request_path, class: "inline-flex items-center gap-2 px-6 py-2.5 bg-gradient-to-r from-primary-600 to-purple-600 text-white rounded-xl hover:shadow-lg transition-all font-bold" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
          </svg>
          <span>새 체크</span>
        <% end %>

        <!-- 프로필 -->
        <%= link_to customers_profile_path, class: "flex items-center gap-2 text-gray-700 hover:text-primary-600 transition-colors" do %>
          <div class="w-9 h-9 bg-primary-100 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
            </svg>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</nav>

<!-- 하단 네비게이션 공간 확보 (모바일) -->
<div class="h-16 md:hidden"></div>
