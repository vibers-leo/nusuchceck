<%# 사용법: render "shared/form_errors", resource: @request %>

<% if local_assigns[:resource] && resource.errors.any? %>
  <div class="bg-red-50 border-2 border-red-300 rounded-2xl p-5 mb-6 shake" role="alert">
    <div class="flex items-center mb-3">
      <svg class="w-6 h-6 text-red-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span class="text-red-900 font-bold text-base">입력 오류가 있습니다!</span>
    </div>
    <ul class="space-y-2 text-sm text-red-800">
      <% resource.errors.full_messages.each do |message| %>
        <li class="flex items-start gap-2">
          <span class="text-red-600 font-bold">•</span>
          <span><%= message %></span>
        </li>
      <% end %>
    </ul>
    <%
      # 주소 오류가 있는지 확인
      has_address_error = resource.errors.keys.any? { |key| [:address, :detailed_address].include?(key) }
    %>
    <% if has_address_error %>
      <div class="mt-3 p-3 bg-primary-50 border border-primary-200 rounded-lg">
        <p class="text-xs text-primary-900 flex items-start gap-2">
          <svg class="w-4 h-4 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
          <span>아래 <strong>"다음 →" 버튼</strong>을 눌러서 <strong>2단계(위치 정보)</strong>로 이동한 후, <strong>"주소 검색" 버튼</strong>을 눌러 주소를 입력해주세요.</span>
        </p>
      </div>
    <% end %>
  </div>
<% end %>
